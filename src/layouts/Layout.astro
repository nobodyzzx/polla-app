---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { supabase } from '@/lib/supabase';

interface NavProfile {
  username: string;
  puntos_totales: number;
  es_referi: boolean;
}

interface Props {
  title: string;
  description?: string;
  /** Pass the already-fetched profile to avoid a redundant DB call in Layout */
  navProfile?: NavProfile | null;
  /** Pass true if page already confirmed the user is logged in */
  isAuthed?: boolean;
  /** Pass user.id to show pending predictions badge */
  userId?: string;
}
const { title, description = 'Polla Mundial 2026', navProfile, isAuthed, userId } = Astro.props;

let profile: NavProfile | null = navProfile ?? null;
let showNav = isAuthed ?? false;
let pendingCount = 0;

const pathname = Astro.url.pathname;
const navLink = (href: string) => {
  const active = pathname === href || (href !== '/' && pathname.startsWith(href));
  return active
    ? 'flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-gold/15 text-gold font-semibold text-sm border border-gold/25 transition'
    : 'flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-slate-400 hover:text-white hover:bg-brand-800/50 transition text-sm';
};

if (!isAuthed) {
  const accessToken = Astro.cookies.get('sb-access-token')?.value;
  const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
  if (accessToken && refreshToken) {
    const { data: { user } } = await supabase.auth.setSession({
      access_token: accessToken,
      refresh_token: refreshToken,
    });
    showNav = !!user;
    if (user && !navProfile) {
      const { data } = await supabase
        .from('profiles')
        .select('username, puntos_totales, es_referi')
        .eq('id', user.id)
        .single();
      profile = data;
    }
  }
}

// Badge de pronósticos pendientes
if (userId && showNav) {
  const cutoff = new Date(Date.now() + 2 * 3600 * 1000).toISOString();
  const [{ data: openMatches }, { data: myPreds }] = await Promise.all([
    supabase.from('matches')
      .select('id')
      .eq('is_finished', false)
      .gt('match_date', cutoff)
      .not('home_team', 'ilike', 'TBD%')
      .not('away_team', 'ilike', 'TBD%')
      .not('home_team', 'ilike', 'Winner%')
      .not('away_team', 'ilike', 'Winner%'),
    supabase.from('predictions').select('match_id').eq('user_id', userId),
  ]);
  const predictedIds = new Set((myPreds ?? []).map(p => p.match_id));
  pendingCount = (openMatches ?? []).filter(m => !predictedIds.has(m.id)).length;
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Polla 2026</title>
    <link rel="icon" href="/logo-fifa2026.png" />
    <ClientRouter />
  </head>
  <script>
    import { polyfillCountryFlagEmojis } from 'country-flag-emoji-polyfill';
    polyfillCountryFlagEmojis();
  </script>
  <script is:inline>
    let menuAbort = null;
    let menuOpenedAt = 0;

    function openMenu(menu) {
      menuOpenedAt = Date.now();
      menu.classList.remove('hidden');
      requestAnimationFrame(() => {
        menu.style.opacity = '1';
        menu.style.transform = 'scaleY(1)';
      });
    }
    function closeMenu(menu) {
      menu.style.opacity = '0';
      menu.style.transform = 'scaleY(0.95)';
      setTimeout(() => menu.classList.add('hidden'), 180);
    }

    function initMenu() {
      if (menuAbort) menuAbort.abort();
      menuAbort = new AbortController();
      const signal = menuAbort.signal;

      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (!btn || !menu) return;

      menu.style.opacity = '0';
      menu.style.transform = 'scaleY(0.95)';

      btn.addEventListener('click', () => {
        menu.classList.contains('hidden') ? openMenu(menu) : closeMenu(menu);
      }, { signal });

      menu.querySelectorAll('a, button').forEach(el =>
        el.addEventListener('click', () => closeMenu(menu), { signal })
      );

      let scrollTimer;
      window.addEventListener('scroll', () => {
        if (menu.classList.contains('hidden')) return;
        // Ignorar scroll durante 500ms tras abrir (el tap mobile genera micro-scroll)
        if (Date.now() - menuOpenedAt < 500) return;
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => closeMenu(menu), 250);
      }, { passive: true, signal });
    }
    document.addEventListener('DOMContentLoaded', initMenu);
    document.addEventListener('astro:page-load', initMenu);

    // ── Toast notifications ──────────────────────────────────────
    function removeToast(toast) {
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(-10px) scale(0.97)';
      setTimeout(() => toast.remove(), 280);
    }

    function showToast(text, type) {
      const container = document.getElementById('toast-container');
      if (!container || !text) return;

      const isErr = type === 'err';
      const accentColor = isErr ? 'rgba(239,68,68,0.85)' : 'rgba(74,222,128,0.85)';
      const borderColor = isErr ? 'rgba(239,68,68,0.35)' : 'rgba(74,222,128,0.35)';

      const toast = document.createElement('div');
      toast.style.cssText = `
        opacity:0;
        transform:translateY(-12px) scale(0.97);
        transition:opacity 280ms ease,transform 280ms ease;
        display:flex;
        align-items:stretch;
        overflow:hidden;
        border-radius:1rem;
        background:#0f172a;
        border:1px solid ${borderColor};
        box-shadow:0 20px 40px rgba(0,0,0,0.6);
        pointer-events:auto;
      `;

      // Barra de acento izquierda (estilo standings)
      const accent = document.createElement('div');
      accent.style.cssText = `
        width:3px;
        flex-shrink:0;
        background:linear-gradient(to bottom,transparent,${accentColor},transparent);
      `;

      // Contenido
      const inner = document.createElement('div');
      inner.style.cssText = 'display:flex;align-items:flex-start;gap:12px;padding:14px 16px;flex:1;';

      const icon = document.createElement('span');
      icon.style.cssText = 'font-size:1.1rem;flex-shrink:0;margin-top:1px;';
      icon.textContent = isErr ? '❌' : '✅';

      const msgEl = document.createElement('p');
      msgEl.style.cssText = 'font-size:0.875rem;color:#f1f5f9;flex:1;line-height:1.4;font-weight:500;margin:0;';
      msgEl.textContent = text;

      const closeBtn = document.createElement('button');
      closeBtn.style.cssText = 'color:#475569;font-size:1.25rem;line-height:1;flex-shrink:0;background:none;border:none;cursor:pointer;padding:0;margin-top:-2px;';
      closeBtn.textContent = '×';
      closeBtn.addEventListener('mouseover', () => closeBtn.style.color = '#f1f5f9');
      closeBtn.addEventListener('mouseout',  () => closeBtn.style.color = '#475569');
      closeBtn.addEventListener('click', () => { clearTimeout(timer); removeToast(toast); });

      inner.append(icon, msgEl, closeBtn);
      toast.append(accent, inner);
      container.appendChild(toast);

      requestAnimationFrame(() => {
        toast.style.opacity = '1';
        toast.style.transform = 'translateY(0) scale(1)';
      });

      const timer = setTimeout(() => removeToast(toast), 4500);
    }

    // ── Scroll restore tras redirect de formulario ───────────────
    function attachScrollSave() {
      document.querySelectorAll('form').forEach(form => {
        if (form._scrollSave) return;
        form._scrollSave = true;
        form.addEventListener('submit', () => {
          sessionStorage.setItem('restoreScrollY', String(Math.round(window.scrollY)));
        });
      });
    }

    function initToasts() {
      // Restaurar posición de scroll si venimos de un submit
      const savedY = sessionStorage.getItem('restoreScrollY');
      if (savedY) {
        sessionStorage.removeItem('restoreScrollY');
        window.scrollTo({ top: parseInt(savedY, 10), behavior: 'instant' });
      }

      const params = new URLSearchParams(window.location.search);
      const msg = params.get('msg');
      const err = params.get('err') || params.get('error');

      if (msg) showToast(decodeURIComponent(msg), 'msg');
      if (err) showToast(decodeURIComponent(err), 'err');

      if (msg || err) {
        const url = new URL(window.location.href);
        url.searchParams.delete('msg');
        url.searchParams.delete('err');
        url.searchParams.delete('error');
        history.replaceState({}, '', url.toString());
      }

      attachScrollSave();
    }

    document.addEventListener('DOMContentLoaded', initToasts);
    document.addEventListener('astro:page-load', initToasts);
  </script>
  <body class="min-h-screen bg-brand-950 text-slate-100 antialiased">

    {import.meta.env.PUBLIC_BETA === 'true' && (
      <div class="bg-amber-500/15 border-b border-amber-500/30 text-center py-2 px-4 text-xs text-amber-300 sticky top-0 z-[60]">
        🚧 <strong>Versión de prueba</strong> — los datos y pronósticos pueden resetearse antes del lanzamiento oficial
      </div>
    )}

    <nav class="bg-brand-950/95 backdrop-blur-md sticky top-0 z-50 border-b border-brand-800/60">
      <!-- FIFA accent gradient line -->
      <div class="h-[2px] bg-gradient-to-r from-fifared via-gold to-fifared"></div>
      <div class="max-w-5xl mx-auto px-3 h-14 flex items-center justify-between gap-2">

        <a href="/" class="flex items-center gap-2 min-h-[48px] flex-shrink-0">
          <img src="/logo-fifa2026.png" alt="FIFA 2026" class="h-7 sm:h-8 object-contain" />
        </a>

        {showNav ? (
          <>
            {/* ── Desktop: nav horizontal completo ── */}
            <div class="hidden sm:flex items-center gap-0.5 flex-1 justify-center">
              <a href="/dashboard"   class={navLink('/dashboard')}>🏆 Tabla</a>
              <a href="/grupos"      class={navLink('/grupos')}>📊 Grupos</a>
              <a href="/predictions" class={`${navLink('/predictions')} relative`}>
                📅 Partidos
                {pendingCount > 0 && (
                  <span class="absolute -top-1 -right-1 min-w-[16px] h-4 px-1 bg-fifared text-white text-[10px] font-bold rounded-full flex items-center justify-center leading-none">
                    {pendingCount}
                  </span>
                )}
              </a>
              <a href="/resultados"  class={navLink('/resultados')}>📋 Resultados</a>
              <a href="/reglas"      class={navLink('/reglas')}>📖 Reglas</a>
              {profile?.es_referi && (
                <div class="relative group">
                  <button class={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-semibold transition ${pathname.startsWith('/admin') ? 'bg-gold/15 text-gold' : 'text-gold/70 hover:text-gold hover:bg-gold/10'}`}>
                    ⚖️ VAR
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2 hidden group-hover:block z-50">
                    <div class="bg-brand-900 border border-brand-700 rounded-xl shadow-2xl overflow-hidden min-w-[180px]">
                      <a href="/admin"             class={`flex items-center gap-2 px-4 py-3 text-sm hover:bg-brand-800 transition ${pathname === '/admin' ? 'text-gold' : 'text-gold/80'}`}>⚖️ Panel VAR</a>
                      <div class="h-px bg-brand-800" />
                      <a href="/admin/usuarios"    class={`flex items-center gap-2 px-4 py-3 text-sm hover:bg-brand-800 transition ${pathname === '/admin/usuarios' ? 'text-gold' : 'text-gold/70'}`}>👥 Usuarios</a>
                      <div class="h-px bg-brand-800" />
                      <a href="/admin/pronosticos" class={`flex items-center gap-2 px-4 py-3 text-sm hover:bg-brand-800 transition ${pathname === '/admin/pronosticos' ? 'text-gold' : 'text-gold/70'}`}>📋 Pronósticos</a>
                      <div class="h-px bg-brand-800" />
                      <a href="/resumen"           class={`flex items-center gap-2 px-4 py-3 text-sm hover:bg-brand-800 transition ${pathname === '/resumen' ? 'text-gold' : 'text-gold/70'}`}>📊 Resumen</a>
                    </div>
                  </div>
                </div>
              )}
            </div>

            {/* ── Desktop: perfil + salir ── */}
            <div class="hidden sm:flex items-center gap-1 flex-shrink-0">
              <a href="/perfil" class={`flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm transition ${pathname === '/perfil' ? 'bg-gold/15 text-gold border border-gold/25' : 'hover:bg-brand-800/50 text-slate-300'}`}>
                <span class="w-6 h-6 rounded-full bg-gradient-to-br from-gold/60 to-gold/30 flex items-center justify-center text-[11px] font-bold text-brand-950 flex-shrink-0">
                  {(profile?.username ?? '?')[0].toUpperCase()}
                </span>
                <span class="font-medium">{profile?.username}</span>
                <span class="text-gold font-bold text-xs">{profile?.puntos_totales ?? 0}p</span>
              </a>
              <form method="POST" action="/api/auth/logout">
                <button class="flex items-center justify-center w-9 h-9 rounded-lg text-slate-500 hover:text-fifared hover:bg-fifared/10 transition" title="Cerrar sesión">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                  </svg>
                </button>
              </form>
            </div>

            {/* ── Mobile: accesos rápidos + hamburguesa ── */}
            <div class="flex sm:hidden items-center gap-1">
              <a href="/predictions"
                class={`relative flex items-center justify-center w-10 h-10 rounded-lg transition text-lg ${pathname.startsWith('/predictions') ? 'bg-gold/15 text-gold border border-gold/25' : 'text-slate-400 active:bg-brand-800'}`}
                title="Pronósticos">
                📅
                {pendingCount > 0 && (
                  <span class="absolute top-0.5 right-0.5 min-w-[15px] h-[15px] px-0.5 bg-fifared text-white text-[9px] font-bold rounded-full flex items-center justify-center leading-none">
                    {pendingCount}
                  </span>
                )}
              </a>
              <a href="/perfil"
                class={`flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs transition ${pathname === '/perfil' ? 'bg-gold/15 border border-gold/25' : 'text-slate-300 active:bg-brand-800'}`}>
                <span class="w-5 h-5 rounded-full bg-gradient-to-br from-gold/60 to-gold/30 flex items-center justify-center text-[10px] font-bold text-brand-950">
                  {(profile?.username ?? '?')[0].toUpperCase()}
                </span>
                <span class="text-gold font-bold">{profile?.puntos_totales ?? 0}p</span>
              </a>
              <button id="menu-btn"
                class="flex items-center justify-center w-10 h-10 rounded-lg text-slate-400 active:bg-brand-800 transition"
                aria-label="Menú">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
              </button>
            </div>
          </>
        ) : (
          <div class="flex items-center gap-2">
            <a href="/reglas" class={`text-sm px-3 py-1.5 rounded-lg transition ${pathname === '/reglas' ? 'bg-gold/15 text-gold border border-gold/25' : 'text-slate-400 hover:text-white hover:bg-brand-800/50'}`}>
              📖 Reglas
            </a>
            <a href="/pago" class={`text-sm px-3 py-1.5 rounded-lg transition ${pathname === '/pago' ? 'bg-gold/15 text-gold border border-gold/25' : 'text-slate-400 hover:text-white hover:bg-brand-800/50'}`}>
              💰 Cómo pagar
            </a>
            <a href="/login" class="bg-gold text-brand-950 font-bold px-4 py-2 flex items-center rounded-lg transition text-sm active:opacity-80">
              Entrar →
            </a>
          </div>
        )}
      </div>

      {/* ── Mobile: menú desplegable ── */}
      {showNav && (
        <div id="mobile-menu"
          class="hidden sm:hidden border-t border-brand-800/60 bg-brand-950/98 backdrop-blur-md">

          <div class="max-w-5xl mx-auto px-4 py-3 space-y-1">

            {/* Usuario */}
            <a href="/perfil" class={`flex items-center gap-3 px-3 py-3 rounded-xl transition ${pathname === '/perfil' ? 'bg-brand-800' : 'hover:bg-brand-900 active:bg-brand-800'}`}>
              <span class="w-8 h-8 rounded-full bg-gradient-to-br from-gold/60 to-gold/30 flex items-center justify-center text-sm font-bold text-brand-950 flex-shrink-0">
                {(profile?.username ?? '?')[0].toUpperCase()}
              </span>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-semibold text-white">{profile?.username}</div>
                <div class="text-xs text-slate-500">Mi perfil</div>
              </div>
              <span class="text-gold font-bold text-sm">{profile?.puntos_totales ?? 0} pts</span>
            </a>

            <div class="h-px bg-brand-800 my-1" />

            {[
              { href: '/dashboard',   icon: '🏆', label: 'Tabla de posiciones' },
              { href: '/grupos',      icon: '📊', label: 'Grupos y Eliminatorias' },
              { href: '/predictions', icon: '📅', label: 'Mis Pronósticos', startsWith: true },
              { href: '/resultados',  icon: '📋', label: 'Resultados' },
              { href: '/reglas',      icon: '📖', label: 'Reglamento' },
              { href: '/pago',        icon: '💰', label: 'Cómo pagar' },
            ].map(({ href, icon, label, startsWith }) => {
              const active = startsWith ? pathname.startsWith(href) : pathname === href;
              return (
                <a href={href} class={`flex items-center gap-3 px-3 py-3 rounded-xl text-sm transition ${active ? 'bg-brand-800 text-white font-semibold' : 'text-slate-300 hover:bg-brand-900 active:bg-brand-800'}`}>
                  <span class="text-lg w-7 text-center flex-shrink-0">{icon}</span>
                  <span>{label}</span>
                  {active && <div class="ml-auto w-1.5 h-1.5 rounded-full bg-gold"></div>}
                </a>
              );
            })}

            {profile?.es_referi && (
              <>
                <div class="h-px bg-brand-800 my-1" />
                {[
                  { href: '/admin',             label: 'Panel VAR' },
                  { href: '/admin/usuarios',    label: 'Usuarios' },
                  { href: '/admin/pronosticos', label: 'Pronósticos' },
                  { href: '/resumen',           label: 'Resumen' },
                ].map(({ href, label }) => (
                  <a href={href} class={`flex items-center gap-3 px-3 py-3 rounded-xl text-sm transition ${pathname === href ? 'bg-gold/15 text-gold font-semibold' : 'text-gold/70 hover:bg-gold/10 active:bg-gold/15'}`}>
                    <span class="text-lg w-7 text-center flex-shrink-0">⚖️</span>
                    <span>{label}</span>
                  </a>
                ))}
              </>
            )}

            <div class="h-px bg-brand-800 my-1" />
            <form method="POST" action="/api/auth/logout">
              <button class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm text-slate-500 active:text-fifared active:bg-fifared/10 transition w-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                <span>Cerrar sesión</span>
              </button>
            </form>

          </div>
        </div>
      )}
    </nav>

    <!-- Toast container -->
    <div id="toast-container" class="fixed top-4 right-4 z-[200] flex flex-col gap-2 w-[calc(100vw-2rem)] sm:w-80 pointer-events-none"></div>

    <main class="max-w-5xl mx-auto px-4 py-6 sm:py-8">
      <slot />
    </main>

    <footer class="border-t border-brand-800 mt-12 py-6 text-center text-xs text-slate-500 px-4">
      Polla Mundial 2026 &middot; Réferi: Yeye &middot; No es democracia, es competición ⚽
    </footer>

  </body>
</html>
