---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Página no encontrada">
  <div class="flex flex-col items-center justify-center py-24 text-center gap-6">
    <div class="font-display text-[8rem] leading-none text-brand-800 select-none">404</div>
    <div>
      <h1 class="text-2xl font-bold text-white mb-2">Página no encontrada</h1>
      <p class="text-slate-500 text-sm">Esta jugada no existe. El VAR ha revisado y confirma: fuera de cancha.</p>
    </div>
    <a href="/dashboard" class="bg-gold text-brand-950 font-bold px-6 py-2.5 rounded-xl text-sm hover:opacity-90 transition">
      Volver al inicio
    </a>
  </div>
</Layout>
