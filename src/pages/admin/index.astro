---
import Layout from '@/layouts/Layout.astro';
import { supabase, supabaseAdmin } from '@/lib/supabase';
import { betaNow } from '@/lib/betaTime';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: { user } } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: profile } = await supabase
  .from('profiles')
  .select('es_referi, username, puntos_totales')
  .eq('id', user.id)
  .single();

if (!profile?.es_referi) return Astro.redirect('/dashboard');

const { data: matches } = await supabase
  .from('matches')
  .select('*')
  .eq('is_finished', false)
  .order('match_date', { ascending: true })
  .limit(20);


const { data: profiles } = await supabaseAdmin
  .from('profiles')
  .select('*')
  .order('expulsado', { ascending: true })
  .order('puntos_totales', { ascending: false });


// Configuración general
const { data: settingsRows } = await supabaseAdmin.from('settings').select('key, value');
const settings = new Map((settingsRows ?? []).map((r: any) => [r.key, r.value]));
const pagosDeadline70: string = settings.get('pagos_deadline_70') ?? '';
const pagosDeadline50: string = settings.get('pagos_deadline_50') ?? '';

// Parsea deadline con backward compat: sin TZ → era Bolivia, con TZ → OK
function parseDeadline(iso: string): Date {
  const withTz = /Z|[+-]\d{2}:\d{2}$/.test(iso) ? iso : iso + '-04:00';
  return new Date(withTz);
}
function deadlineStatus(iso: string) {
  if (!iso) return null;
  return parseDeadline(iso) < new Date() ? 'vencido' : 'activo';
}
// Convierte UTC ISO → "YYYY-MM-DDTHH:MM" en hora Bolivia para el input
function toBoliviaInput(iso: string): string {
  if (!iso) return '';
  const d = parseDeadline(iso);
  if (isNaN(d.getTime())) return '';
  const boliviaMs = d.getTime() - 4 * 3600 * 1000;
  return new Date(boliviaMs).toISOString().slice(0, 16);
}

// Última sincronización: partido terminado más recientemente actualizado
const { data: lastSyncedMatch } = await supabaseAdmin
  .from('matches')
  .select('home_team, away_team, home_score, away_score, match_date')
  .eq('is_finished', true)
  .order('match_date', { ascending: false })
  .limit(1)
  .maybeSingle();

// Sanciones activas — para saber qué botones deshabilitar
const { data: activeSanctions } = await supabaseAdmin
  .from('sanctions')
  .select('id, user_id, type')
  .eq('active', true);

type SanctionEntry = { id: string; type: string };
const sanctionsByUser = new Map<string, SanctionEntry[]>();
for (const s of activeSanctions ?? []) {
  const arr = sanctionsByUser.get(s.user_id) ?? [];
  arr.push({ id: s.id, type: s.type });
  sanctionsByUser.set(s.user_id, arr);
}

function formatDate(d: string) {
  return new Date(d).toLocaleString('es-BO', {
    day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit',
    timeZone: 'America/La_Paz',
    hour12: false
  });
}
---

<Layout title="Panel Réferi" navProfile={profile} isAuthed={true}>
  <div class="space-y-8">

    <!-- Header -->
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="font-display text-4xl text-white tracking-wide">⚖️ PANEL DEL RÉFERI</h1>
      <span class="text-sm text-gold bg-gold/10 border border-gold/30 px-3 py-2 rounded-full self-start sm:self-auto">
        {profile.username}
      </span>
    </div>

    <!-- ── ACCESOS RÁPIDOS ── -->
    <div class="grid grid-cols-3 gap-3">
      <a href="/admin/usuarios"
        class="flex flex-col items-center justify-center gap-1.5 bg-brand-900 border border-brand-700/60 rounded-2xl py-4 px-2 hover:border-brand-600 transition min-h-[80px]">
        <span class="text-2xl">👥</span>
        <span class="text-xs font-semibold text-slate-300">Usuarios</span>
      </a>
      <a href="/admin/pronosticos"
        class="flex flex-col items-center justify-center gap-1.5 bg-brand-900 border border-brand-700/60 rounded-2xl py-4 px-2 hover:border-brand-600 transition min-h-[80px]">
        <span class="text-2xl">📋</span>
        <span class="text-xs font-semibold text-slate-300">Pronósticos</span>
      </a>
      <a href="/admin/bracket"
        class="flex flex-col items-center justify-center gap-1.5 bg-brand-900 border border-brand-700/60 rounded-2xl py-4 px-2 hover:border-brand-600 transition min-h-[80px]">
        <span class="text-2xl">🏆</span>
        <span class="text-xs font-semibold text-slate-300">Bracket</span>
      </a>
      <button id="btn-run-tests-quick"
        class="flex flex-col items-center justify-center gap-1.5 bg-brand-900 border border-brand-700/60 rounded-2xl py-4 px-2 hover:border-brand-600 transition min-h-[80px]">
        <span class="text-2xl">🧪</span>
        <span class="text-xs font-semibold text-slate-300">Tests</span>
      </button>
    </div>
    <div id="test-results" class="hidden space-y-1.5"></div>

    <!-- ── API DE FÚTBOL ── -->
    <section class="space-y-3">
      <h2 class="font-display text-2xl text-white tracking-wide border-b border-brand-800 pb-2">
        🌐 API DE FÚTBOL
      </h2>
      <div class="bg-brand-900 border border-brand-700/60 rounded-2xl p-4 space-y-4">

        <div class="flex items-center justify-between">
          <span class="text-xs text-slate-500">Proveedor:</span>
          <a href="https://www.football-data.org" target="_blank" rel="noopener"
            class="text-xs text-gold/80 hover:text-gold transition font-mono">football-data.org</a>
        </div>

        <div class="text-xs text-slate-500 space-y-1">
          <span class="text-slate-400">Códigos de torneo:</span>
          <span class="block">WC = Mundial · CL = Champions · PL = Premier · PD = La Liga · SA = Serie A</span>
        </div>

        <button id="btn-check-api"
          class="w-full bg-brand-800/40 border border-brand-700/40 text-slate-500 text-xs px-3 py-2 rounded-xl transition active:bg-brand-700 text-left">
          🔍 Ver torneos disponibles en mi plan →
        </button>
        <div id="api-competitions" class="hidden text-xs space-y-1 max-h-40 overflow-y-auto"></div>

        <div class="flex gap-2">
          <input id="api-code" type="text" placeholder="Código (ej: CL)" maxlength="10"
            class="flex-1 bg-brand-800 border border-brand-700 rounded-xl px-3 py-2.5 text-white text-sm uppercase focus:outline-none focus:border-gold transition" />
          <input id="api-season" type="number" placeholder="Temporada" min="2020" max="2030"
            class="w-28 bg-brand-800 border border-brand-700 rounded-xl px-3 py-2.5 text-white text-sm focus:outline-none focus:border-gold transition" />
        </div>

        <div class="grid grid-cols-2 gap-2">
          <form method="POST" action="/api/admin/import-fixture" id="form-import">
            <input type="hidden" name="code"   id="import-code" />
            <input type="hidden" name="season" id="import-season" />
            <button type="submit"
              class="w-full bg-brand-800 border border-brand-700 text-slate-300 text-sm font-semibold px-3 py-3 rounded-xl transition active:bg-brand-700 min-h-[48px]">
              📥 Importar Fixture
            </button>
          </form>
          <form method="POST" action="/api/admin/sync-scores" id="form-sync">
            <input type="hidden" name="code"   id="sync-code" />
            <input type="hidden" name="season" id="sync-season" />
            <button type="submit"
              class="w-full bg-gold/10 border border-gold/40 text-gold text-sm font-semibold px-3 py-3 rounded-xl transition active:bg-gold/20 min-h-[48px]">
              🔄 Sync Scores
            </button>
          </form>
        </div>

        {import.meta.env.PUBLIC_BETA === 'true' && (
        <div class="border-t border-brand-800 pt-3 grid grid-cols-2 gap-2">
          <div class="space-y-1">
            <form method="POST" action="/api/admin/seed-demo" id="form-seed">
              <button type="submit"
                class="w-full bg-brand-800/60 border border-brand-600/50 text-slate-400 text-sm font-semibold px-2 py-3 rounded-xl transition active:bg-brand-700 min-h-[48px]">
                🧪 Datos de Prueba
              </button>
            </form>
            <p class="text-xs text-slate-600 text-center">2 grupos + elim.</p>
          </div>
          <div class="space-y-1">
            <form method="POST" action="/api/admin/seed-knockout">
              <button type="submit"
                class="w-full bg-brand-800/60 border border-brand-600/50 text-slate-400 text-sm font-semibold px-2 py-3 rounded-xl transition active:bg-brand-700 min-h-[48px]">
                🏆 Solo Eliminatorias
              </button>
            </form>
            <p class="text-xs text-slate-600 text-center">Con penales</p>
          </div>
          <div class="space-y-1">
            <form method="POST" action="/api/admin/simulate" id="form-simulate">
              <button type="submit"
                class="w-full bg-brand-700/50 border border-brand-600/60 text-slate-300 text-sm font-semibold px-2 py-3 rounded-xl transition active:bg-brand-600 min-h-[48px]">
                🎲 Simular Juego
              </button>
            </form>
            <p class="text-xs text-slate-600 text-center">Pronósticos aleatorios</p>
          </div>
          <div class="space-y-1">
            <form method="POST" action="/api/admin/advance-dates" id="form-advance">
              <button type="submit"
                class="w-full bg-gold/10 border border-gold/30 text-gold text-sm font-semibold px-2 py-3 rounded-xl transition active:bg-gold/20 min-h-[48px]">
                ⏩ Adelantar Fechas
              </button>
            </form>
            <p class="text-xs text-slate-600 text-center">Todo al pasado</p>
          </div>
          <div class="space-y-1">
            <button type="button" onclick="document.getElementById('modal-clear').classList.remove('hidden')"
              class="w-full bg-fifared/8 border border-fifared/30 text-fifared text-sm font-semibold px-2 py-3 rounded-xl transition active:bg-fifared/20 min-h-[48px]">
              🗑️ Limpiar Todo
            </button>
            <p class="text-xs text-slate-600 text-center">Resetea todo</p>
          </div>
        </div>
        )}

      </div>
    </section>

    <!-- ── RESULTADOS ── -->
    <section class="space-y-4">

      <div class="space-y-4">
          <button id="toggle-manual"
            class="w-full flex items-center justify-between border-b border-brand-800 pb-2 group">
            <h2 class="font-display text-2xl text-white tracking-wide">📊 CARGA MANUAL</h2>
            <span id="toggle-manual-icon" class="text-slate-500 text-sm transition">▼ mostrar</span>
          </button>
          <p class="text-xs text-slate-600 -mt-2">Respaldo por si la API falla. Normalmente usar 🔄 Sync Scores.</p>
          <div id="manual-section" class="hidden space-y-4">

            {(!matches || matches.length === 0) && (
              <p class="text-slate-600 text-sm">No hay partidos pendientes de resultado.</p>
            )}

            <div class="flex flex-col gap-4">
              {(matches ?? []).map((m: any) => (
                <form method="POST" action="/api/admin/score"
                  class="bg-brand-900 border border-brand-700/60 rounded-2xl p-4 space-y-4">
                  <input type="hidden" name="matchId" value={m.id} />
                  <div>
                    <div class="text-xs text-slate-500 uppercase tracking-wide mb-1">
                      {m.stage === 'group' ? `Grupo ${m.group_name}` : m.round}
                      {m.jornada && <span class="ml-1 text-brand-600">· {m.jornada}</span>}
                      <span class="ml-2 text-slate-500">· {formatDate(m.match_date)}</span>
                    </div>
                    <div class="font-semibold text-white text-base">
                      {m.home_team} <span class="text-slate-500">vs</span> {m.away_team}
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="flex-1 text-center space-y-1">
                      <span class="text-xs text-slate-500 block truncate">{m.home_team}</span>
                      <input type="number" name="homeScore" min="0" max="20" required placeholder="0"
                        class="w-full bg-brand-800 border border-brand-700 rounded-xl px-2 py-4 text-white text-2xl font-display text-center focus:outline-none focus:border-gold transition" />
                    </div>
                    <span class="text-brand-600 text-xl flex-shrink-0">—</span>
                    <div class="flex-1 text-center space-y-1">
                      <span class="text-xs text-slate-500 block truncate">{m.away_team}</span>
                      <input type="number" name="awayScore" min="0" max="20" required placeholder="0"
                        class="w-full bg-brand-800 border border-brand-700 rounded-xl px-2 py-4 text-white text-2xl font-display text-center focus:outline-none focus:border-gold transition" />
                    </div>
                  </div>
                  {m.stage === 'knockout' && (
                    <div class="space-y-1">
                      <span class="text-xs text-gold block">Score penales (si aplica):</span>
                      <div class="flex items-center gap-2">
                        <div class="flex-1 text-center space-y-1">
                          <span class="text-xs text-slate-500 block truncate">{m.home_team}</span>
                          <input type="number" name="homePen" min="0" max="20" placeholder="–"
                            class="w-full bg-gold/10 border border-gold/40 rounded-xl px-2 py-3 text-gold text-xl font-display text-center focus:outline-none focus:border-gold transition placeholder:text-gold/30" />
                        </div>
                        <span class="text-gold/40 text-lg flex-shrink-0">–</span>
                        <div class="flex-1 text-center space-y-1">
                          <span class="text-xs text-slate-500 block truncate">{m.away_team}</span>
                          <input type="number" name="awayPen" min="0" max="20" placeholder="–"
                            class="w-full bg-gold/10 border border-gold/40 rounded-xl px-2 py-3 text-gold text-xl font-display text-center focus:outline-none focus:border-gold transition placeholder:text-gold/30" />
                        </div>
                      </div>
                    </div>
                  )}
                  <button type="submit"
                    class="w-full bg-gol text-white text-sm font-bold px-4 py-3 rounded-xl transition active:bg-gol-hover min-h-[48px]">
                    Guardar y Calcular ✅
                  </button>
                </form>
              ))}
            </div>
          </div>
        </div>
    </section>

    <!-- ── VAR: SANCIONES ── -->
    <section class="space-y-3">
      <h2 class="font-display text-2xl text-white tracking-wide border-b border-brand-800 pb-2">
        🟨 VAR: SANCIONES
      </h2>

      {/* Stats rápidas */}
      {(() => {
        const jug = (profiles ?? []).filter((p: any) => p.participa);
        const pagados   = jug.filter((p: any) => p.pago_70 && p.pago_50).length;
        const parcial   = jug.filter((p: any) => p.pago_70 && !p.pago_50).length;
        const sancion   = jug.filter((p: any) => (sanctionsByUser.get(p.id) ?? []).length > 0).length;
        const expuls    = jug.filter((p: any) => p.expulsado).length;
        return (
          <div class="grid grid-cols-4 gap-2 text-center">
            <div class="bg-brand-900 border border-gol/30 rounded-xl py-2.5">
              <div class="font-display text-2xl text-gol">{pagados}</div>
              <div class="text-[10px] text-slate-500 mt-0.5">Pagados</div>
            </div>
            <div class="bg-brand-900 border border-gold/30 rounded-xl py-2.5">
              <div class="font-display text-2xl text-gold">{parcial}</div>
              <div class="text-[10px] text-slate-500 mt-0.5">Parcial</div>
            </div>
            <div class="bg-brand-900 border border-amarilla/30 rounded-xl py-2.5">
              <div class="font-display text-2xl text-amarilla">{sancion}</div>
              <div class="text-[10px] text-slate-500 mt-0.5">Sancionados</div>
            </div>
            <div class="bg-brand-900 border border-fifared/30 rounded-xl py-2.5">
              <div class="font-display text-2xl text-fifared">{expuls}</div>
              <div class="text-[10px] text-slate-500 mt-0.5">Expulsados</div>
            </div>
          </div>
        );
      })()}

      {/* Lista compacta */}
      <div class="flex flex-col gap-2">
        {(profiles ?? []).filter((p: any) => p.participa).map((p: any) => {
          const isExpulsado = p.expulsado === true;
          const userSanctions = sanctionsByUser.get(p.id) ?? [];
          const hasActiveRed = userSanctions.some((s: any) => s.type === 'red' || s.type === 'double_red');
          return (
            <div class={`rounded-xl border px-3 py-3 space-y-2.5 ${isExpulsado ? 'bg-fifared/5 border-fifared/20' : 'bg-brand-900 border-brand-700/60'}`}>

              {/* Fila 1: nombre + chips sanciones + pts + pago */}
              <div class="flex items-center gap-2 flex-wrap">
                <span class={`font-semibold text-sm ${isExpulsado ? 'text-slate-500 line-through' : 'text-white'}`}>
                  {p.username}
                </span>
                {isExpulsado && <span class="text-[10px] text-red-400 font-bold">🟥🟥 EXPULSADO</span>}
                {userSanctions.map((s: any) => {
                  const icon  = s.type === 'yellow' ? '🟨' : '🟥';
                  const label = s.type === 'yellow' ? 'Amarilla' : s.type === 'red' ? 'Roja' : '2ª Roja';
                  const cls   = s.type === 'yellow' ? 'border-amarilla/40 text-amarilla bg-amarilla/10' : 'border-fifared/40 text-fifared bg-fifared/10';
                  return (
                    <form method="POST" action="/api/admin/undo-sanction" class="inline">
                      <input type="hidden" name="sanctionId" value={s.id} />
                      <button type="submit" onclick="return confirm('¿Anular esta sanción?')"
                        class={`inline-flex items-center gap-1 text-[10px] px-1.5 py-0.5 rounded-full border font-semibold transition ${cls}`}>
                        {icon} {label} ×
                      </button>
                    </form>
                  );
                })}
                <span class="ml-auto font-display text-sm text-gold">{p.puntos_totales}pts</span>
                {!isExpulsado && (
                  <span class={`text-[10px] px-2 py-0.5 rounded-full border font-semibold ${
                    p.pago_70 && p.pago_50 ? 'bg-gol/10 border-gol/30 text-gol' :
                    p.pago_70             ? 'bg-gold/10 border-gold/30 text-gold' :
                                            'bg-fifared/10 border-fifared/30 text-fifared'
                  }`}>
                    {p.pago_70 && p.pago_50 ? '✓ pagado' : p.pago_70 ? '⏳ parcial' : '❌ pendiente'}
                  </span>
                )}
              </div>

              {/* Fila 2: botones de acción (solo si no expulsado) */}
              {!isExpulsado && (
                <div class="flex items-center gap-1.5 flex-wrap">
                  <form method="POST" action="/api/admin/sanction">
                    <input type="hidden" name="userId" value={p.id} />
                    <input type="hidden" name="type" value="yellow" />
                    <input type="hidden" name="reason" value="Advertencia del réferi" />
                    <button type="submit" onclick={`return confirm('¿Aplicar amarilla a ${p.username}?')`}
                      class="text-xs px-2.5 py-1.5 rounded-lg border bg-amarilla/10 border-amarilla/40 text-amarilla active:bg-amarilla/20 min-h-[36px]">
                      🟨 Amarilla
                    </button>
                  </form>
                  <form method="POST" action="/api/admin/sanction">
                    <input type="hidden" name="userId" value={p.id} />
                    <input type="hidden" name="type" value="red" />
                    <input type="hidden" name="reason" value="Tarjeta roja — jornada anulada" />
                    <button type="submit" disabled={hasActiveRed} onclick={!hasActiveRed ? `return confirm('¿Aplicar roja a ${p.username}? Se anulará su jornada.')` : undefined}
                      class={`text-xs px-2.5 py-1.5 rounded-lg border min-h-[36px] ${hasActiveRed ? 'bg-brand-800/40 border-brand-700/30 text-slate-600 cursor-not-allowed' : 'bg-fifared/10 border-fifared/40 text-fifared active:bg-fifared/20'}`}>
                      🟥 Roja
                    </button>
                  </form>
                  <form method="POST" action="/api/admin/sanction">
                    <input type="hidden" name="userId" value={p.id} />
                    <input type="hidden" name="type" value="double_red" />
                    <input type="hidden" name="reason" value="Doble roja — expulsión definitiva" />
                    <button type="submit" onclick="return confirm('¿Expulsión definitiva?')"
                      class="text-xs px-2.5 py-1.5 rounded-lg border bg-fifared-dark/20 border-fifared-dark/50 text-red-300 active:bg-fifared-dark/40 min-h-[36px]">
                      🟥🟥 2ª Roja
                    </button>
                  </form>
                  <div class="ml-auto flex items-center gap-1.5 flex-wrap justify-end">
                    <form method="POST" action="/api/admin/payment">
                      <input type="hidden" name="userId" value={p.id} />
                      <input type="hidden" name="field" value="pago70" />
                      <input type="hidden" name="value" value={p.pago_70 ? 'false' : 'true'} />
                      <button type="submit"
                        class={`text-xs px-2.5 py-1.5 rounded-lg border font-semibold min-h-[36px] ${p.pago_70 ? 'bg-gol/10 border-gol/40 text-gol' : 'bg-brand-800 border-brand-700 text-slate-400'}`}>
                        {p.pago_70 ? '✓' : '+'} 70Bs
                      </button>
                    </form>
                    <form method="POST" action="/api/admin/payment">
                      <input type="hidden" name="userId" value={p.id} />
                      <input type="hidden" name="field" value="pago50" />
                      <input type="hidden" name="value" value={p.pago_50 ? 'false' : 'true'} />
                      <button type="submit" disabled={!p.pago_70}
                        class={`text-xs px-2.5 py-1.5 rounded-lg border font-semibold min-h-[36px] ${!p.pago_70 ? 'bg-brand-800/40 border-brand-700/30 text-slate-600 cursor-not-allowed' : p.pago_50 ? 'bg-gol/10 border-gol/40 text-gol' : 'bg-gold/10 border-gold/50 text-gold'}`}>
                        {p.pago_50 ? '✓' : '+'} 50Bs
                      </button>
                    </form>
                    <form method="POST" action="/api/admin/set-monto-pagado" class="flex items-center gap-1">
                      <input type="hidden" name="user_id" value={p.id} />
                      <input type="hidden" name="back" value="/admin" />
                      <input name="monto_pagado" type="number" min="0" max="9999"
                        value={p.monto_pagado ?? 0}
                        title="Monto total depositado en Bs"
                        class="w-16 bg-brand-800 border border-brand-700 rounded-lg px-2 py-1.5 text-xs text-white font-mono text-center focus:outline-none focus:border-gold/50 min-h-[36px]" />
                      <button type="submit"
                        class="text-xs px-2 py-1.5 rounded-lg border bg-brand-800 border-brand-700 text-slate-400 hover:text-white hover:border-brand-600 transition min-h-[36px]"
                        title="Guardar monto depositado">
                        Bs ✓
                      </button>
                    </form>
                  </div>
                </div>
              )}

            </div>
          );
        })}
      </div>
    </section>

    <!-- ── CONFIGURACIÓN ── -->
    <section class="space-y-3">
      <h2 class="font-display text-2xl text-white tracking-wide border-b border-brand-800 pb-2">
        ⚙️ CONFIGURACIÓN
      </h2>

      <!-- Cron status -->
      <div class="bg-brand-900 border border-brand-700/60 rounded-2xl p-4 space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-slate-300">🔄 Sync automático</span>
          <span class="text-xs text-slate-500 bg-brand-800 border border-brand-700 px-2 py-1 rounded-full font-mono">
            */5 11-23 * * *
          </span>
        </div>
        <p class="text-xs text-slate-600">
          Cron via <span class="text-slate-500">pg_cron + pg_net</span> en Supabase —
          <code class="text-slate-400 bg-brand-800 px-1 rounded">*/5 16-23,0-5 * * *</code>
          (cada 5 min · 12:00–01:59 Bolivia · 2 llamadas/run a football-data.org).
          Se activa ejecutando
          <code class="text-slate-400 bg-brand-800 px-1 rounded">20260101000008_cron_sync.sql</code>
          en DataGrip con la URL de producción.
        </p>
        {lastSyncedMatch && (
          <div class="text-xs text-slate-500 border-t border-brand-800 pt-2">
            Último resultado cargado:
            <span class="text-slate-300 ml-1">
              {lastSyncedMatch.home_team} {lastSyncedMatch.home_score}–{lastSyncedMatch.away_score} {lastSyncedMatch.away_team}
            </span>
          </div>
        )}
      </div>

      <div class="bg-brand-900 border border-brand-700/60 rounded-2xl p-4">
        <form method="POST" action="/api/admin/save-settings" class="space-y-5">
          <p class="text-xs text-slate-600">
            Cuando se supere cada fecha, el botón "Compartir pagos" del dashboard se desactiva automáticamente.
          </p>

          <!-- 1er pago -->
          <div class="space-y-1.5">
            <label class="text-xs text-slate-400 uppercase tracking-wide font-semibold">
              1er Pago — 70 Bs
            </label>
            <div class="flex items-center gap-3 flex-wrap">
              <input type="datetime-local" name="pagos_deadline_70"
                value={toBoliviaInput(pagosDeadline70)}
                class="bg-brand-800 border border-brand-700 text-slate-200 text-sm rounded-xl px-3 py-2.5 focus:outline-none focus:border-gold transition" />
              {pagosDeadline70 && (
                <span class={`text-xs font-semibold px-2 py-1 rounded-full border ${
                  deadlineStatus(pagosDeadline70) === 'vencido'
                    ? 'text-fifared border-fifared/30 bg-fifared/10'
                    : 'text-gol border-gol/30 bg-gol/10'
                }`}>
                  {deadlineStatus(pagosDeadline70) === 'vencido' ? '🔒 Vencido' : '✅ Activo'}
                </span>
              )}
            </div>
          </div>

          <!-- 2do pago -->
          <div class="space-y-1.5">
            <label class="text-xs text-slate-400 uppercase tracking-wide font-semibold">
              2do Pago — 50 Bs
            </label>
            <div class="flex items-center gap-3 flex-wrap">
              <input type="datetime-local" name="pagos_deadline_50"
                value={toBoliviaInput(pagosDeadline50)}
                class="bg-brand-800 border border-brand-700 text-slate-200 text-sm rounded-xl px-3 py-2.5 focus:outline-none focus:border-gold transition" />
              {pagosDeadline50 && (
                <span class={`text-xs font-semibold px-2 py-1 rounded-full border ${
                  deadlineStatus(pagosDeadline50) === 'vencido'
                    ? 'text-fifared border-fifared/30 bg-fifared/10'
                    : 'text-gol border-gol/30 bg-gol/10'
                }`}>
                  {deadlineStatus(pagosDeadline50) === 'vencido' ? '🔒 Vencido' : '✅ Activo'}
                </span>
              )}
            </div>
          </div>

          <button type="submit"
            class="bg-brand-700 hover:bg-brand-600 border border-brand-600 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition min-h-[44px]">
            Guardar configuración
          </button>
        </form>
      </div>

      <!-- Modo de la app -->
      <div class={`border rounded-2xl p-4 space-y-3 ${import.meta.env.PUBLIC_BETA === 'true' ? 'bg-amber-500/10 border-amber-500/40' : 'bg-gol/10 border-gol/30'}`}>
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-slate-300">
            {import.meta.env.PUBLIC_BETA === 'true' ? '🚧 Modo actual: VERSIÓN DE PRUEBA' : '🚀 Modo actual: VERSIÓN OFICIAL'}
          </span>
          <span class={`text-xs px-2 py-1 rounded-full font-mono border ${import.meta.env.PUBLIC_BETA === 'true' ? 'bg-amber-500/20 border-amber-500/40 text-amber-300' : 'bg-gol/20 border-gol/30 text-green-300'}`}>
            PUBLIC_BETA={import.meta.env.PUBLIC_BETA ?? 'false'}
          </span>
        </div>
        {import.meta.env.PUBLIC_BETA === 'true' ? (
          <div class="space-y-3">
            <p class="text-xs text-slate-500">
              En versión de prueba los jugadores pueden pronosticar sin importar si pagaron. Al lanzar la versión oficial se borran <strong class="text-slate-400">todos los pronósticos y puntos</strong>. Los pagos se conservan.
            </p>
            <p class="text-xs text-amber-400/80">
              Después del reset: cambiá <code class="bg-brand-800 px-1 rounded">PUBLIC_BETA=false</code> en <code class="bg-brand-800 px-1 rounded">.env</code> y redesplegá la app.
            </p>
            <form method="POST" action="/api/admin/launch-official"
              onsubmit="return confirm('¿Confirmas el lanzamiento oficial? Se borrarán TODOS los pronósticos y puntos. Esta acción no se puede deshacer.')">
              <button type="submit"
                class="bg-fifared/20 hover:bg-fifared/30 border border-fifared/50 text-red-300 text-sm font-bold px-5 py-2.5 rounded-xl transition min-h-[44px] w-full">
                🚀 Lanzar versión oficial y resetear todo
              </button>
            </form>
          </div>
        ) : (
          <p class="text-xs text-slate-500">
            La app está en modo oficial. Los pronósticos están bloqueados para jugadores que no hayan completado ambos pagos.
          </p>
        )}
      </div>
    </section>

  </div>
</Layout>

<script is:inline>
  function initAdminForms() {
    // Copiar league/season a los hidden fields de import y sync antes del submit
    const codeInput   = document.getElementById('api-code');
    const seasonInput = document.getElementById('api-season');

    // Restaurar última configuración usada
    const savedCode   = localStorage.getItem('api_code');
    const savedSeason = localStorage.getItem('api_season');
    if (savedCode   && codeInput)   codeInput.value   = savedCode;
    if (savedSeason && seasonInput) seasonInput.value = savedSeason;

    ['import', 'sync'].forEach(prefix => {
      const form = document.getElementById(`form-${prefix}`);
      if (!form) return;
      form.addEventListener('submit', function() {
        const code   = codeInput?.value?.toUpperCase() ?? '';
        const season = seasonInput?.value ?? '';
        document.getElementById(`${prefix}-code`).value   = code;
        document.getElementById(`${prefix}-season`).value = season;
        // Persistir para la próxima vez
        if (code)   localStorage.setItem('api_code',   code);
        if (season) localStorage.setItem('api_season', season);
      });
    });

    // Toggle carga manual
    const toggleBtn = document.getElementById('toggle-manual');
    const manualSection = document.getElementById('manual-section');
    const toggleIcon = document.getElementById('toggle-manual-icon');
    if (toggleBtn && manualSection && !toggleBtn._toggleInit) {
      toggleBtn._toggleInit = true;
      toggleBtn.addEventListener('click', () => {
        const hidden = manualSection.classList.toggle('hidden');
        toggleIcon.textContent = hidden ? '▼ mostrar' : '▲ ocultar';
      });
    }

    // Tests del reglamento
    const btnTests = document.getElementById('btn-run-tests-quick');
    const testResultsDiv = document.getElementById('test-results');
    if (btnTests && testResultsDiv && !btnTests._testsInit) {
      btnTests._testsInit = true;
      btnTests.addEventListener('click', async () => {
        btnTests.querySelector('span:last-child').textContent = 'Calculando…';
        btnTests.disabled = true;
        testResultsDiv.classList.remove('hidden');
        testResultsDiv.innerHTML = '<p class="text-xs text-slate-500">Calculando…</p>';
        try {
          const res = await fetch('/api/admin/run-tests', { method: 'POST' });
          const data = await res.json();
          if (data.error) {
            testResultsDiv.innerHTML = `<p class="text-xs text-fifared">${data.error}</p>`;
          } else {
            const allPass = data.passed === data.total;
            testResultsDiv.innerHTML = `
              <div class="flex items-center gap-2 px-3 py-2 rounded-xl border ${allPass ? 'border-gol/30 bg-gol/8 text-gol' : 'border-amarilla/30 bg-amarilla/8 text-amarilla'} text-sm font-semibold">
                ${allPass ? '✅' : '⚠️'} ${data.passed}/${data.total} tests pasaron
              </div>
              ${data.tests.map((t) => `
                <div class="flex items-start gap-2 px-3 py-2 rounded-lg ${t.passed ? 'bg-brand-800/30' : 'bg-fifared/8 border border-fifared/20'}">
                  <span class="flex-shrink-0 text-xs mt-0.5">${t.passed ? '✅' : '❌'}</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-xs font-semibold ${t.passed ? 'text-slate-300' : 'text-fifared'}">${t.name}</div>
                    <div class="text-xs text-slate-500">${t.description}</div>
                    ${!t.passed ? `<div class="text-xs text-fifared mt-0.5">esperado: ${t.expected} · obtenido: ${t.actual ?? 'null'} ${t.note ? '· ' + t.note : ''}</div>` : ''}
                  </div>
                  <span class="text-xs font-mono flex-shrink-0 ${t.passed ? 'text-slate-500' : 'text-fifared'}">${t.actual ?? '?'} pts</span>
                </div>
              `).join('')}
            `;
          }
        } catch (e) {
          testResultsDiv.innerHTML = `<p class="text-xs text-fifared">Error de red</p>`;
        }
        btnTests.querySelector('span:last-child').textContent = 'Tests';
        btnTests.disabled = false;
      });
    }

    // Botón consultar torneos disponibles
    const btnCheck = document.getElementById('btn-check-api');
    const apiCompDiv = document.getElementById('api-competitions');
    if (btnCheck && apiCompDiv && !btnCheck._checkInit) {
      btnCheck._checkInit = true;
      btnCheck.addEventListener('click', async () => {
        btnCheck.textContent = '⏳ Consultando…';
        btnCheck.disabled = true;
        try {
          const res = await fetch('/api/admin/check-api');
          const data = await res.json();
          if (data.error) {
            apiCompDiv.innerHTML = `<span class="text-fifared">${data.error}</span>`;
          } else {
            apiCompDiv.innerHTML = data.competitions
              .map((c) => `<div class="flex gap-2 py-0.5 border-b border-brand-800/40">
                <span class="text-gold font-mono w-10 flex-shrink-0">${c.code}</span>
                <span class="text-slate-300 flex-1">${c.name}</span>
                <span class="text-slate-600">${c.area}</span>
              </div>`)
              .join('');
          }
          apiCompDiv.classList.remove('hidden');
          btnCheck.textContent = '🔍 Ver torneos disponibles en mi plan →';
          btnCheck.disabled = false;
        } catch (e) {
          apiCompDiv.innerHTML = `<span class="text-fifared">Error de red</span>`;
          apiCompDiv.classList.remove('hidden');
          btnCheck.textContent = '🔍 Ver torneos disponibles en mi plan →';
          btnCheck.disabled = false;
        }
      });
    }

    // El modal de confirmación se maneja con HTML puro (ver #modal-clear)

    // Loading state en todos los forms del panel
    document.querySelectorAll('form[action^="/api/admin/"]').forEach((form) => {
      if (form._adminInit) return;
      form._adminInit = true;
      form.addEventListener('submit', function() {
        const btn = form.querySelector('button[type="submit"]');
        if (!btn || btn.disabled) return;
        btn.disabled = true;
        btn.textContent = '⏳ Enviando…';
        btn.style.opacity = '0.6';
        btn.style.cursor = 'wait';
      });
    });
  }
  document.addEventListener('DOMContentLoaded', initAdminForms);
  document.addEventListener('astro:page-load', initAdminForms);
</script>

<!-- ── Modal: confirmar Limpiar Todo ─────────────────────────────── -->
<div id="modal-clear" class="hidden fixed inset-0 z-[300] flex items-center justify-center px-4">
  <div class="absolute inset-0 bg-brand-950/80 backdrop-blur-sm" onclick="document.getElementById('modal-clear').classList.add('hidden')"></div>
  <div class="relative z-10 bg-brand-900 border border-fifared/50 rounded-2xl p-6 max-w-sm w-full space-y-4 shadow-2xl">
    <div class="flex items-center gap-3">
      <span class="text-2xl">⚠️</span>
      <h3 class="text-white font-bold text-lg">Limpiar competición</h3>
    </div>
    <p class="text-slate-300 text-sm">
      Esto borrará <strong class="text-fifared">TODOS</strong> los partidos, pronósticos y sanciones, y reseteará los puntos a 0.
    </p>
    <p class="text-slate-400 text-sm">
      Para confirmar, escribí <code class="bg-brand-800 px-1.5 py-0.5 rounded text-fifared font-mono">LIMPIAR TODO</code> abajo:
    </p>
    <form method="POST" action="/api/admin/clear-matches" class="space-y-3">
      <input name="confirm_phrase" type="text" placeholder="LIMPIAR TODO"
        autocomplete="off" autocorrect="off" autocapitalize="characters" spellcheck="false"
        class="w-full bg-brand-800 border border-brand-700 rounded-xl px-4 py-3 text-base text-white placeholder-slate-500 focus:outline-none focus:border-fifared transition font-mono uppercase tracking-widest" />
      <div class="flex gap-2">
        <button type="button" onclick="document.getElementById('modal-clear').classList.add('hidden')"
          class="flex-1 bg-brand-800 border border-brand-700 text-slate-300 font-semibold py-3 rounded-xl transition active:bg-brand-700 min-h-[48px]">
          Cancelar
        </button>
        <button type="submit"
          class="flex-1 bg-fifared/20 border border-fifared/50 text-fifared font-bold py-3 rounded-xl transition active:bg-fifared/30 min-h-[48px]">
          Limpiar
        </button>
      </div>
    </form>
  </div>
</div>

<script is:inline>
</script>
