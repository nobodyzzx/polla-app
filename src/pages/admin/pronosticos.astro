---
import Layout from '@/layouts/Layout.astro';
import { supabase, supabaseAdmin } from '@/lib/supabase';
import { betaNowMs } from '@/lib/betaTime';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: { user } } = await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: navProfile } = await supabase.from('profiles').select('username, puntos_totales, es_referi').eq('id', user.id).single();
if (!navProfile?.es_referi) return Astro.redirect('/dashboard');

const ahora = new Date(betaNowMs()).toISOString();

const [
  { data: rawMatches },
  { data: rawPlayers },
] = await Promise.all([
  supabaseAdmin.from('matches').select('id, home_team, away_team, home_score, away_score, home_pen, away_pen, winner_penalties, stage, group_name, round, jornada, match_date, is_finished').order('match_date', { ascending: true }),
  supabaseAdmin.from('profiles').select('id, username').eq('participa', true).eq('expulsado', false).order('puntos_totales', { ascending: false }),
]);

const allMatches = rawMatches ?? [];
const players    = rawPlayers ?? [];

// Cargar todos los pronósticos
const allMatchIds = allMatches.map((m: any) => m.id);
const rawPreds = allMatchIds.length
  ? (await supabaseAdmin.from('predictions')
      .select('user_id, match_id, user_home, user_away, user_home_pen, user_away_pen, points_earned')
      .in('match_id', allMatchIds)
    ).data ?? []
  : [];

// predMap: match_id → user_id → pred
const predMap: Record<string, Record<string, any>> = {};
for (const p of rawPreds) {
  if (!predMap[p.match_id]) predMap[p.match_id] = {};
  predMap[p.match_id][p.user_id] = p;
}

// Agrupar por jornada
const jornadaOrder: string[] = [];
const jornadaMatches: Record<string, any[]> = {};
for (const m of allMatches) {
  const k = (m as any).jornada ?? 'Sin jornada';
  if (!jornadaMatches[k]) { jornadaMatches[k] = []; jornadaOrder.push(k); }
  jornadaMatches[k].push(m);
}

function predLabel(pred: any, m: any): string {
  if (!pred) return '—';
  const s = `${pred.user_home}–${pred.user_away}`;
  if (pred.user_home_pen !== null && pred.user_away_pen !== null)
    return `${s} (${pred.user_home_pen}–${pred.user_away_pen})`;
  return s;
}

function predClass(pred: any, m: any): string {
  if (!pred) return 'text-slate-700';
  if (!m.is_finished) return 'text-slate-300';
  if (pred.points_earned === null) return 'text-slate-500';
  if (pred.user_home === m.home_score && pred.user_away === m.away_score) return 'text-gold font-bold';
  const pr = pred.user_home > pred.user_away ? 'H' : pred.user_home < pred.user_away ? 'A' : 'E';
  const mr = m.home_score  > m.away_score  ? 'H' : m.home_score  < m.away_score  ? 'A' : 'E';
  if (pr === mr) return 'text-gol';
  return 'text-slate-500';
}

function ptsLabel(pred: any, m: any): string {
  if (!pred || !m.is_finished || pred.points_earned === null) return '';
  return `${pred.points_earned}p`;
}
---

<Layout title="Pronósticos" navProfile={navProfile} isAuthed={true}>
  <div class="space-y-6">

    <div class="flex items-center justify-between gap-2 flex-wrap">
      <div>
        <h1 class="font-display text-4xl text-white tracking-wide">PRONÓSTICOS</h1>
        <p class="text-slate-500 text-sm mt-1">Vista consolidada · {players.length} participantes · {allMatches.length} partidos</p>
      </div>
      <a href="/admin" class="text-xs text-slate-500 hover:text-white transition px-3 py-1.5 border border-brand-700 rounded-lg flex-shrink-0">
        ← Panel VAR
      </a>
    </div>

    {jornadaOrder.length === 0 && (
      <div class="text-center py-20 text-slate-600">
        <div class="text-5xl mb-4">📋</div>
        <p>No hay partidos cargados aún.</p>
      </div>
    )}

    {jornadaOrder.map((jornada) => {
      const matches = jornadaMatches[jornada];
      const allFinished = matches.every((m: any) => m.is_finished);
      const anyFinished = matches.some((m: any) => m.is_finished);
      return (
        <details open={!allFinished} class="group bg-brand-900 border border-brand-700/60 rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer list-none select-none">
            <div class="flex items-center gap-3">
              <span class="font-display text-lg text-white tracking-wide">{jornada.toUpperCase()}</span>
              <span class={`text-xs px-2 py-0.5 rounded-full border ${allFinished ? 'border-brand-600 text-slate-500' : anyFinished ? 'border-gold/40 text-gold' : 'border-gol/40 text-gol'}`}>
                {allFinished ? 'Terminada' : anyFinished ? 'En curso' : 'Pendiente'}
              </span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs text-slate-600">{matches.length} partido{matches.length !== 1 ? 's' : ''}</span>
              <svg class="w-4 h-4 text-slate-600 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </summary>

          <div class="border-t border-brand-800">
            {matches.map((m: any) => {
              const preds = predMap[m.id] ?? {};
              const submitted = players.filter((pl: any) => preds[pl.id]);
              const missing   = players.filter((pl: any) => !preds[pl.id]);
              const isClosed  = new Date(m.match_date).getTime() - 7200000 < betaNowMs();
              return (
                <div class="border-b border-brand-800/60 last:border-b-0">
                  {/* Cabecera del partido */}
                  <div class="px-5 py-3 bg-brand-800/40 flex items-center gap-3 flex-wrap">
                    <div class="flex items-center gap-2 flex-1 min-w-0">
                      <span class="text-sm font-semibold text-white truncate">{m.home_team}</span>
                      <span class="text-brand-600 font-display text-sm flex-shrink-0">
                        {m.is_finished ? `${m.home_score}–${m.away_score}` : 'vs'}
                      </span>
                      <span class="text-sm font-semibold text-white truncate">{m.away_team}</span>
                    </div>
                    <div class="flex items-center gap-2 flex-shrink-0 text-xs">
                      <span class="text-slate-600">
                        {new Date(m.match_date).toLocaleDateString('es-CL', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' })}
                      </span>
                      {m.is_finished
                        ? <span class="text-gol bg-gol/10 border border-gol/20 px-2 py-0.5 rounded-full">✓ Terminado</span>
                        : isClosed
                        ? <span class="text-gold bg-gold/10 border border-gold/20 px-2 py-0.5 rounded-full">🔒 Cerrado</span>
                        : <span class="text-slate-500 bg-brand-800 border border-brand-700 px-2 py-0.5 rounded-full">Abierto</span>
                      }
                      <span class="text-slate-500">{submitted.length}/{players.length} apostaron</span>
                    </div>
                  </div>

                  {/* Pronósticos */}
                  <div class="px-5 py-3">
                    <div class="flex flex-wrap gap-x-4 gap-y-1.5">
                      {players.map((pl: any) => {
                        const pred = preds[pl.id];
                        return (
                          <div class="flex items-center gap-1.5 min-w-[120px]">
                            <span class="text-xs text-slate-500 truncate max-w-[70px]">{pl.username}</span>
                            <span class={`text-xs font-mono ${predClass(pred, m)}`}>
                              {predLabel(pred, m)}
                            </span>
                            {m.is_finished && pred && (
                              <span class={`text-[10px] font-bold ${pred.points_earned > 0 ? 'text-gol' : 'text-slate-600'}`}>
                                {ptsLabel(pred, m)}
                              </span>
                            )}
                          </div>
                        );
                      })}
                    </div>

                    {missing.length > 0 && !m.is_finished && (
                      <div class="mt-2 flex items-center gap-1.5 flex-wrap">
                        <span class="text-[11px] text-fifared/70">Sin pronóstico:</span>
                        {missing.map((pl: any) => (
                          <span class="text-[11px] text-fifared/60 bg-fifared/5 border border-fifared/20 px-1.5 py-0.5 rounded">{pl.username}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </details>
      );
    })}

  </div>
</Layout>
