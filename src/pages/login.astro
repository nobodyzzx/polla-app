---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) return Astro.redirect('/dashboard');

const error = Astro.url.searchParams.get('error');
const message = Astro.url.searchParams.get('message');
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Entrar | Polla 2026</title>
    <link rel="icon" href="/logo-fifa2026.png" />
    <ClientRouter />
  </head>
  <script>
    import { polyfillCountryFlagEmojis } from 'country-flag-emoji-polyfill';
    polyfillCountryFlagEmojis();
  </script>
  <body class="min-h-screen antialiased">

    <!-- Background image + overlay -->
    <div
      class="fixed inset-0 bg-cover bg-center bg-no-repeat"
      style="background-image: url('/bg-login.jpg')"
    ></div>
    <div class="fixed inset-0 bg-brand-950/78"></div>

    <!-- Content -->
    <div class="relative z-10 min-h-screen flex flex-col items-center justify-center px-4 py-10">

      <!-- Logo & host countries -->
      <div class="mb-7 text-center">
        <img src="/logo-fifa2026.png" alt="FIFA World Cup 2026" class="h-24 sm:h-28 mx-auto object-contain drop-shadow-2xl" />
        <div class="flex items-center justify-center gap-3 mt-3 text-2xl">
          <span title="Estados Unidos">🇺🇸</span>
          <span class="text-brand-600">·</span>
          <span title="Canadá">🇨🇦</span>
          <span class="text-brand-600">·</span>
          <span title="México">🇲🇽</span>
        </div>
      </div>

      <!-- Card -->
      <div class="w-full max-w-sm">
        <div class="bg-brand-900/85 backdrop-blur-md border border-brand-700/70 rounded-2xl p-6 sm:p-8 space-y-5 shadow-2xl">

          <div class="text-center space-y-1">
            <h1 class="text-xl font-bold text-white tracking-wide">Polla Mundial 2026</h1>
            <p class="text-slate-400 text-sm">Ingresa para continuar</p>
          </div>

          {error && (
            <div class="bg-fifared/20 border border-fifared/50 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
              {error}
            </div>
          )}
          {message && (
            <div class="bg-gol/10 border border-gol/30 rounded-xl px-4 py-3 text-sm text-green-300 text-center">
              {message}
            </div>
          )}

          <form method="POST" action="/api/auth/login" class="space-y-4">
            <div class="space-y-1.5">
              <label class="text-sm text-slate-400 block">Correo electrónico</label>
              <input name="email" type="email" required placeholder="tu@correo.com"
                class="w-full bg-brand-800 border border-brand-700 rounded-xl px-4 py-3.5 text-base text-white placeholder-slate-500 focus:outline-none focus:border-gold transition" />
            </div>
            <div class="space-y-1.5">
              <label class="text-sm text-slate-400 block">
                Contraseña <span class="text-slate-600 text-xs">(opcional — vacía para magic link)</span>
              </label>
              <div class="relative">
                <input id="password-input" name="password" type="password" placeholder="••••••••"
                  class="w-full bg-brand-800 border border-brand-700 rounded-xl px-4 py-3.5 pr-12 text-base text-white placeholder-slate-500 focus:outline-none focus:border-gold transition" />
                <button type="button" id="toggle-password"
                  class="absolute right-0 top-0 h-full w-12 flex items-center justify-center text-slate-500 hover:text-slate-300 transition touch-manipulation"
                  aria-label="Mostrar contraseña">
                  <svg id="icon-eye" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                  </svg>
                  <svg id="icon-eye-off" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                  </svg>
                </button>
              </div>
            </div>
            <button type="submit"
              class="w-full bg-gold text-brand-950 font-bold py-4 rounded-xl transition active:bg-gold-dark text-base min-h-[52px] mt-1">
              Entrar al Mundial
            </button>
          </form>

          <div class="flex items-center justify-between text-xs">
            <a href="/olvidaste" class="text-slate-400 hover:text-white transition">
              ¿Olvidaste tu contraseña?
            </a>
            <span class="text-slate-600">Contacta al Réferi</span>
          </div>
        </div>

        <p class="text-center text-xs text-slate-500 mt-5">
          11 jun – 19 jul 2026 &middot; 48 selecciones &middot; 104 partidos
        </p>
      </div>
    </div>

  <script is:inline>
    var btn   = document.getElementById('toggle-password');
    var input = document.getElementById('password-input');
    var eye   = document.getElementById('icon-eye');
    var eyeOff = document.getElementById('icon-eye-off');
    if (btn && input) {
      btn.addEventListener('click', function () {
        var show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        eye.classList.toggle('hidden', show);
        eyeOff.classList.toggle('hidden', !show);
      });
    }
  </script>
  </body>
</html>
