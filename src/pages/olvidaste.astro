---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) return Astro.redirect('/dashboard');

const error   = Astro.url.searchParams.get('error');
const message = Astro.url.searchParams.get('message');
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recuperar contraseña | Polla 2026</title>
    <link rel="icon" href="/logo-fifa2026.png" />
    <ClientRouter />
  </head>
  <body class="min-h-screen antialiased">

    <div class="fixed inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/bg-login.jpg')"></div>
    <div class="fixed inset-0 bg-brand-950/78"></div>

    <div class="relative z-10 min-h-screen flex flex-col items-center justify-center px-4 py-10">

      <div class="mb-7 text-center">
        <img src="/logo-fifa2026.png" alt="FIFA World Cup 2026" class="h-24 mx-auto object-contain drop-shadow-2xl" />
      </div>

      <div class="w-full max-w-sm">
        <div class="bg-brand-900/85 backdrop-blur-md border border-brand-700/70 rounded-2xl p-6 sm:p-8 space-y-5 shadow-2xl">

          <div class="text-center space-y-1">
            <h1 class="text-xl font-bold text-white tracking-wide">Recuperar contraseña</h1>
            <p class="text-slate-400 text-sm">Te enviamos un link para restablecer tu contraseña</p>
          </div>

          {error && (
            <div class="bg-fifared/20 border border-fifared/50 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
              {error}
            </div>
          )}
          {message && (
            <div class="bg-gol/10 border border-gol/30 rounded-xl px-4 py-3 text-sm text-green-300 text-center">
              {message}
            </div>
          )}

          {!message && (
            <form method="POST" action="/api/auth/reset-request" class="space-y-4">
              <div class="space-y-1.5">
                <label class="text-sm text-slate-300 block">Correo electrónico</label>
                <input name="email" type="email" required placeholder="tu@correo.com"
                  class="w-full bg-brand-800 border border-brand-700 rounded-xl px-4 py-3.5 text-base text-white placeholder-slate-500 focus:outline-none focus:border-gold transition" />
              </div>
              <button type="submit"
                class="w-full bg-gold text-brand-950 font-bold py-4 rounded-xl transition active:bg-gold-dark text-base min-h-[52px]">
                Enviar link de recuperación
              </button>
            </form>
          )}

          <a href="/login" class="block text-center text-sm text-slate-400 hover:text-white transition">
            ← Volver al inicio de sesión
          </a>

        </div>
      </div>
    </div>
  </body>
</html>
