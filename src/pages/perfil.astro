---
import Layout from '@/layouts/Layout.astro';
import { supabase, supabaseAdmin } from '@/lib/supabase';

const accessToken  = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) return Astro.redirect('/login');

const { data: { user }, error: sessionErr } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});
if (sessionErr || !user) return Astro.redirect('/login');

const [{ data: profile }, { data: predHistory }] = await Promise.all([
  supabaseAdmin
    .from('profiles')
    .select('username, puntos_totales, es_referi, pago_70, pago_50')
    .eq('id', user.id)
    .single(),
  supabaseAdmin
    .from('predictions')
    .select('points_earned, match:matches!inner(match_date, jornada, stage, round, group_name, home_team, away_team, is_finished)')
    .eq('user_id', user.id)
    .eq('matches.is_finished', true)
    .order('matches.match_date', { ascending: true }),
]);

// Agrupar por día Bolivia
const jornadaMap = new Map<string, { pts: number; partidos: number; label: string }>();
for (const p of (predHistory ?? []) as any[]) {
  const m = p.match;
  if (!m?.is_finished) continue;
  const dayKey = new Date(m.match_date).toLocaleDateString('es-BO', {
    weekday: 'long', day: 'numeric', month: 'long', timeZone: 'America/La_Paz',
  });
  const label = m.stage === 'group'
    ? (m.group_name ? `Grupo ${m.group_name}` : m.jornada ?? dayKey)
    : (m.round ?? dayKey);
  if (!jornadaMap.has(dayKey)) jornadaMap.set(dayKey, { pts: 0, partidos: 0, label });
  const entry = jornadaMap.get(dayKey)!;
  entry.pts += p.points_earned ?? 0;
  entry.partidos++;
}
const jornadaHistory = [...jornadaMap.entries()].map(([day, v]) => ({ day, ...v }));
---

<Layout title="Mi Perfil" navProfile={profile} isAuthed={true} userId={user.id}>
  <div class="max-w-md mx-auto space-y-6">

    <h1 class="font-display text-4xl text-white tracking-wide">MI PERFIL</h1>

    <!-- Info actual -->
    <div class="bg-brand-900 border border-brand-700/60 rounded-2xl p-5 space-y-3">
      <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide">Tu cuenta</h2>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Usuario</span>
        <span class="font-semibold text-white">{profile?.username}</span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Correo</span>
        <span class="font-semibold text-slate-300 text-sm truncate max-w-[60%] text-right">{user.email}</span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Puntos</span>
        <span class="font-bold text-gold">{profile?.puntos_totales ?? 0} pts</span>
      </div>
      <div class="h-px bg-brand-800"></div>
      <p class="text-xs text-slate-600 uppercase tracking-wide font-semibold">Estado de pagos</p>
      <div class="space-y-2">
        <div class="flex items-center justify-between">
          <div>
            <span class="text-sm text-slate-300">1er pago — 70 Bs</span>
            <p class="text-xs text-slate-600">{profile?.pago_70 ? 'Pronósticos habilitados' : 'Sin esto no puedes pronosticar'}</p>
          </div>
          <span class={`text-xs px-3 py-1 rounded-full font-semibold ${profile?.pago_70 ? 'bg-gol/20 text-green-300 border border-gol/30' : 'bg-amber-900/30 text-amber-400 border border-amber-500/40'}`}>
            {profile?.pago_70 ? '✓ Pagado' : '⚠️ Pronósticos bloqueados'}
          </span>
        </div>
        <div class="flex items-center justify-between">
          <div>
            <span class="text-sm text-slate-300">2do pago — 50 Bs</span>
            <p class="text-xs text-slate-600">{profile?.pago_50 ? 'Participación completa' : 'Sin esto solo aportas 50 Bs al pozo'}</p>
          </div>
          <span class={`text-xs px-3 py-1 rounded-full font-semibold ${profile?.pago_50 ? 'bg-gol/20 text-green-300 border border-gol/30' : 'bg-brand-800 text-slate-500 border border-brand-700'}`}>
            {profile?.pago_50 ? '✓ Pagado' : '⚠️ Pozo incompleto'}
          </span>
        </div>
      </div>
      {!profile?.pago_70 && (
        <a href="/pago" class="flex items-center justify-center gap-2 w-full bg-gold/10 border border-gold/30 text-gold text-sm font-semibold py-2.5 rounded-xl transition active:bg-gold/20">
          💰 Ver cómo pagar →
        </a>
      )}
    </div>

    <!-- Cambiar nombre -->
    <div class="bg-brand-900 border border-brand-700/60 rounded-2xl p-5 space-y-4">
      <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide">Cambiar nombre</h2>
      <form method="POST" action="/api/profile/update" class="space-y-3">
        <input type="hidden" name="field" value="username" />
        <div class="space-y-1.5">
          <div class="flex items-center justify-between">
            <label class="text-sm text-slate-300">Nombre de usuario</label>
            <span id="username-counter" class="text-xs text-slate-600">0/30</span>
          </div>
          <input id="username-input" name="username" type="text" required
            value={profile?.username ?? ''}
            maxlength="30"
            class="w-full bg-brand-800 border border-brand-700 rounded-xl px-4 py-3.5 text-base text-white focus:outline-none focus:border-gold transition" />
        </div>
        <button type="submit"
          class="w-full bg-gold text-brand-950 font-bold py-3 rounded-xl transition active:opacity-80 min-h-[48px]">
          Actualizar nombre
        </button>
      </form>
    </div>

    <!-- Historial de puntos por jornada -->
    {jornadaHistory.length > 0 && (
      <div class="bg-brand-900 border border-brand-700/60 rounded-2xl p-5 space-y-3">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide">Historial de puntos</h2>
          <span class="text-gold font-bold text-sm">{profile?.puntos_totales ?? 0} pts total</span>
        </div>
        <div class="space-y-1.5">
          {jornadaHistory.map(({ day, pts, partidos, label }) => (
            <div class="flex items-center justify-between py-2 border-b border-brand-800/60 last:border-0">
              <div class="min-w-0">
                <p class="text-sm text-slate-300 capitalize leading-tight">{day}</p>
                <p class="text-xs text-slate-600 mt-0.5">{partidos} partido{partidos !== 1 ? 's' : ''}</p>
              </div>
              <span class={`font-display text-xl font-bold flex-shrink-0 ml-3 ${pts >= 6 ? 'text-gold' : pts >= 3 ? 'text-gol' : pts >= 1 ? 'text-slate-300' : 'text-slate-600'}`}>
                {pts}<span class="text-xs font-sans text-slate-500 ml-0.5">pts</span>
              </span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Cambiar contraseña -->
    <div class="bg-brand-900 border border-brand-700/60 rounded-2xl p-5 space-y-4">
      <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide">Cambiar contraseña</h2>
      <form method="POST" action="/api/auth/update-password" class="space-y-3" id="pw-form">
        <div class="space-y-1.5">
          <label class="text-sm text-slate-300 block">Nueva contraseña <span class="text-slate-600">(mín. 8 caracteres)</span></label>
          <div class="relative">
            <input id="pw1" name="password" type="password" required minlength="8" placeholder="••••••••"
              class="w-full bg-brand-800 border border-brand-700 rounded-xl px-4 py-3.5 pr-12 text-base text-white placeholder-slate-500 focus:outline-none focus:border-gold transition" />
            <button type="button" class="eye-toggle absolute right-0 top-0 h-full w-12 flex items-center justify-center text-slate-500 hover:text-slate-300 transition touch-manipulation" data-target="pw1">
              <svg class="eye-icon w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
              <svg class="eye-off-icon w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" /></svg>
            </button>
          </div>
        </div>
        <div class="space-y-1.5">
          <label class="text-sm text-slate-300 block">Confirmá la contraseña</label>
          <div class="relative">
            <input id="pw2" name="confirm_password" type="password" required minlength="8" placeholder="Repetí la contraseña"
              class="w-full bg-brand-800 border border-brand-700 rounded-xl px-4 py-3.5 pr-12 text-base text-white placeholder-slate-500 focus:outline-none focus:border-gold transition" />
            <button type="button" class="eye-toggle absolute right-0 top-0 h-full w-12 flex items-center justify-center text-slate-500 hover:text-slate-300 transition touch-manipulation" data-target="pw2">
              <svg class="eye-icon w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
              <svg class="eye-off-icon w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" /></svg>
            </button>
          </div>
        </div>
        <p id="pw-mismatch" class="text-sm text-red-400 hidden flex items-center gap-1.5">⚠️ Las contraseñas no coinciden</p>
        <button type="submit"
          class="w-full bg-gold text-brand-950 font-bold py-3 rounded-xl transition active:opacity-80 min-h-[48px]">
          Cambiar contraseña
        </button>
      </form>
    </div>

  </div>
</Layout>

<script is:inline>
  function initPerfil() {
    // Eye toggles
    document.querySelectorAll('.eye-toggle').forEach(function(btn) {
      if (btn._eyeInit) return;
      btn._eyeInit = true;
      btn.addEventListener('click', function() {
        var input = document.getElementById(this.getAttribute('data-target'));
        if (!input) return;
        var show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        this.querySelector('.eye-icon').classList.toggle('hidden', show);
        this.querySelector('.eye-off-icon').classList.toggle('hidden', !show);
      });
    });

    // Char counter para username
    var usernameInput = document.getElementById('username-input');
    var counter = document.getElementById('username-counter');
    if (usernameInput && counter && !usernameInput._counterInit) {
      usernameInput._counterInit = true;
      function updateCounter() {
        var len = usernameInput.value.length;
        counter.textContent = len + '/30';
        counter.className = 'text-xs ' + (len >= 28 ? 'text-amber-400' : 'text-slate-600');
      }
      updateCounter();
      usernameInput.addEventListener('input', updateCounter);
    }

    // Validar contraseñas (submit + tiempo real)
    var form = document.getElementById('pw-form');
    if (form && !form._pwInit) {
      form._pwInit = true;
      var pw2Input = document.getElementById('pw2');
      var msg = document.getElementById('pw-mismatch');
      function checkMatch() {
        var match = document.getElementById('pw1').value === pw2Input.value;
        msg.classList.toggle('hidden', match || pw2Input.value === '');
        pw2Input.classList.toggle('border-red-500', !match && pw2Input.value !== '');
        pw2Input.classList.toggle('border-brand-700', match || pw2Input.value === '');
      }
      pw2Input.addEventListener('input', checkMatch);
      form.addEventListener('submit', function(e) {
        var pw1 = document.getElementById('pw1').value;
        var pw2 = pw2Input.value;
        if (pw1 !== pw2) { e.preventDefault(); msg.classList.remove('hidden'); }
      });
    }
  }
  document.addEventListener('DOMContentLoaded', initPerfil);
  document.addEventListener('astro:page-load', initPerfil);
</script>
