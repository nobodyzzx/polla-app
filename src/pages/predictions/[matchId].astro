---
import Layout from '@/layouts/Layout.astro';
import { betaNowMs } from '@/lib/betaTime';
import { supabase } from '@/lib/supabase';
import { spanishName } from '@/lib/isoFlags';
import { boliviaDayStart, isCutoffPassed } from '@/lib/jornada';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: { user } } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { matchId } = Astro.params;
if (!matchId) return Astro.redirect('/predictions');

const { data: match } = await supabase
  .from('matches')
  .select('*')
  .eq('id', matchId)
  .single();

if (!match) return Astro.redirect('/predictions');

// Cierre por jornada: todos los partidos de la misma jornada cierran juntos.
const jornadaQuery = match.jornada
  ? supabase.from('matches').select('match_date').eq('jornada', match.jornada)
  : (() => {
      const shifted = new Date(new Date(match.match_date).getTime() - 4 * 3600 * 1000);
      const start = new Date(Date.UTC(shifted.getUTCFullYear(), shifted.getUTCMonth(), shifted.getUTCDate()) + 4 * 3600 * 1000);
      return supabase.from('matches').select('match_date')
        .gte('match_date', start.toISOString())
        .lt('match_date', new Date(start.getTime() + 24 * 3600 * 1000).toISOString());
    })();

const now = betaNowMs();
const { data: jornadaMatches } = await jornadaQuery;
const firstMatchTime = Math.min(...(jornadaMatches ?? []).map(m => new Date(m.match_date).getTime()));
const isClosed = isCutoffPassed(firstMatchTime, now);

// Bloqueo por día anterior sin terminar o partido en curso del mismo día
const thisMatchTime = new Date(match.match_date).getTime();
const thisMatchNotStarted = thisMatchTime > now;

// Partidos abiertos con fecha anterior a este partido (día anterior sin terminar)
const { data: unfinishedBefore } = await supabase
  .from('matches')
  .select('id')
  .eq('is_finished', false)
  .lt('match_date', match.match_date)
  .limit(1);

// Partidos del mismo día que ya empezaron
const { data: startedSameDay } = await supabase
  .from('matches')
  .select('id')
  .lte('match_date', new Date(now).toISOString())
  .gte('match_date', (() => {
    const d = new Date(match.match_date);
    return boliviaDayStart(d.getTime()).toISOString();
  })())
  .limit(1);

const isLockedByPrevDay = thisMatchNotStarted && (unfinishedBefore ?? []).length > 0;
const isLockedBySameDay = thisMatchNotStarted && (startedSameDay ?? []).length > 0;

if (isClosed || match.is_finished) return Astro.redirect('/predictions?error=cerrado');
if (isLockedByPrevDay || isLockedBySameDay) return Astro.redirect('/predictions?error=en_curso');

const { data: existing } = await supabase
  .from('predictions')
  .select('*')
  .eq('user_id', user.id)
  .eq('match_id', matchId)
  .single();

if (existing) return Astro.redirect('/predictions?info=ya_pronosticado');

const { data: navProfile } = await supabase
  .from('profiles')
  .select('username, puntos_totales, es_referi, monto_pagado')
  .eq('id', user.id)
  .single();

if (import.meta.env.PUBLIC_BETA !== "true" && (navProfile?.monto_pagado ?? 0) < 70) return Astro.redirect('/predictions');

const error = Astro.url.searchParams.get('error');

const matchDate = new Date(match.match_date).toLocaleString('es-BO', {
  weekday: 'long', day: 'numeric', month: 'long',
  hour: '2-digit', minute: '2-digit',
  timeZone: 'America/La_Paz',
    hour12: false
});

const cutoffDate = new Date(firstMatchTime - 2 * 3600 * 1000).toLocaleString('es-BO', {
  hour: '2-digit', minute: '2-digit',
  timeZone: 'America/La_Paz',
    hour12: false
});
---

<Layout title={`${spanishName(match.home_team)} vs ${spanishName(match.away_team)}`} navProfile={navProfile} isAuthed={true}>
  <div class="max-w-md mx-auto space-y-5">

    <!-- Match header -->
    <div class="text-center space-y-2 pt-2">
      <div class="inline-flex items-center gap-2 bg-brand-800 border border-brand-700 rounded-full px-3 py-1 text-xs text-slate-400 uppercase tracking-wide">
        {match.stage === 'group' ? `Grupo ${match.group_name}` : match.round}
        {match.jornada && <span class="text-brand-500">· {match.jornada}</span>}
      </div>
      <h1 class="font-display text-3xl sm:text-4xl text-white leading-tight tracking-wide">
        {spanishName(match.home_team)} <span class="text-brand-600 text-2xl font-sans font-normal">vs</span> {spanishName(match.away_team)}
      </h1>
      <p class="text-sm text-slate-400 capitalize">{matchDate}</p>
      <p class="text-xs text-fifared">⏰ Cierre de jornada: {cutoffDate}</p>
    </div>

    {error && (
      <div class="bg-fifared/15 border border-fifared/40 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
        {error === 'incompleto' ? 'Completa todos los campos requeridos.' : error}
      </div>
    )}

    <!-- Form -->
    <form method="POST" action="/api/predictions/submit"
      class="bg-brand-900 border border-brand-700/60 rounded-2xl p-5 sm:p-6 space-y-6">
      <input type="hidden" name="matchId" value={matchId} />

      <!-- Score inputs -->
      <div class="space-y-3">
        <p class="text-sm text-slate-400 text-center">¿Cuál será el marcador al final?</p>
        <div class="flex items-center gap-3">

          <div class="flex-1 text-center space-y-2">
            <label class="text-xs text-slate-500 block leading-tight font-medium uppercase tracking-wide">
              {spanishName(match.home_team)}
            </label>
            <input
              type="number" inputmode="numeric" pattern="[0-9]*"
              name="userHome" min="0" max="20" required placeholder="0"
              class="w-full bg-brand-800 border-2 border-brand-700 rounded-2xl px-2 py-5 text-white text-4xl font-display text-center focus:outline-none focus:border-gold transition"
              id="input-home"
            />
          </div>

          <div class="text-center flex-shrink-0 space-y-2">
            <div class="text-xs text-transparent block">–</div>
            <div class="text-2xl text-brand-600 font-bold px-1">–</div>
          </div>

          <div class="flex-1 text-center space-y-2">
            <label class="text-xs text-slate-500 block leading-tight font-medium uppercase tracking-wide">
              {spanishName(match.away_team)}
            </label>
            <input
              type="number" inputmode="numeric" pattern="[0-9]*"
              name="userAway" min="0" max="20" required placeholder="0"
              class="w-full bg-brand-800 border-2 border-brand-700 rounded-2xl px-2 py-5 text-white text-4xl font-display text-center focus:outline-none focus:border-gold transition"
              id="input-away"
            />
          </div>
        </div>
      </div>

      <!-- Penalty score selector (knockout only) -->
      {match.stage === 'knockout' && (
        <div id="penalties-section" class="hidden space-y-3 border-t border-brand-800 pt-5">
          <p class="text-sm text-gold text-center font-semibold">
            ⚡ Score en penales
          </p>
          <p class="text-xs text-slate-500 text-center">
            Solo si el marcador es empate al final del tiempo reglamentario
          </p>
          <div class="flex items-center gap-3">
            <div class="flex-1 text-center space-y-2">
              <label class="text-xs text-slate-500 block truncate">{spanishName(match.home_team)}</label>
              <input
                type="number" inputmode="numeric" pattern="[0-9]*"
                name="userHomePen" id="input-pen-home"
                min="0" max="20" placeholder="0"
                class="w-full bg-gold/10 border-2 border-gold/40 rounded-2xl px-2 py-5 text-gold text-4xl font-display text-center focus:outline-none focus:border-gold transition placeholder:text-gold/30"
              />
            </div>
            <div class="text-center flex-shrink-0 space-y-2">
              <div class="text-xs text-transparent block">–</div>
              <div class="text-2xl text-gold/40 font-bold px-1">–</div>
            </div>
            <div class="flex-1 text-center space-y-2">
              <label class="text-xs text-slate-500 block truncate">{spanishName(match.away_team)}</label>
              <input
                type="number" inputmode="numeric" pattern="[0-9]*"
                name="userAwayPen" id="input-pen-away"
                min="0" max="20" placeholder="0"
                class="w-full bg-gold/10 border-2 border-gold/40 rounded-2xl px-2 py-5 text-gold text-4xl font-display text-center focus:outline-none focus:border-gold transition placeholder:text-gold/30"
              />
            </div>
          </div>
          <p class="text-xs text-slate-600 text-center">El ganador se determina automáticamente por el score</p>
        </div>
      )}

      <button type="submit" id="submit-btn"
        class="w-full bg-gold text-brand-950 font-bold py-4 rounded-2xl transition active:bg-gold-dark text-lg min-h-[56px]">
        Enviar Pronóstico ✅
      </button>

      <p class="text-xs text-slate-600 text-center">
        Una vez enviado no podrás modificar tu pronóstico — Tolerancia Cero.
      </p>
    </form>

    <a href="/predictions"
      class="block text-center text-sm text-slate-600 active:text-slate-400 transition py-3 min-h-[48px] flex items-center justify-center">
      ← Volver a partidos
    </a>
  </div>
</Layout>

<script>
  document.querySelector('form')?.addEventListener('submit', () => {
    const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Enviando…';
      btn.classList.remove('bg-gold', 'active:bg-gold-dark');
      btn.classList.add('bg-gol', 'opacity-75', 'cursor-not-allowed');
    }
  });
</script>

{match.stage === 'knockout' && (
  <script>
    const homeInput = document.getElementById('input-home') as HTMLInputElement;
    const awayInput = document.getElementById('input-away') as HTMLInputElement;
    const penaltiesSection = document.getElementById('penalties-section');

    function checkDraw() {
      const h = parseInt(homeInput?.value ?? '');
      const a = parseInt(awayInput?.value ?? '');
      if (!isNaN(h) && !isNaN(a) && h === a) {
        penaltiesSection?.classList.remove('hidden');
      } else {
        penaltiesSection?.classList.add('hidden');
        const radios = document.querySelectorAll('input[name="userWinnerPenalties"]') as NodeListOf<HTMLInputElement>;
        radios.forEach(r => r.checked = false);
      }
    }

    homeInput?.addEventListener('input', checkDraw);
    awayInput?.addEventListener('input', checkDraw);
  </script>
)}
