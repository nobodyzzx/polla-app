---
import Layout from '@/layouts/Layout.astro';
import { supabase } from '@/lib/supabase';
import { betaNowMs } from '@/lib/betaTime';
import { isCutoffPassed, boliviaDayStart } from '@/lib/jornada';
import { isoForTeam, spanishName } from '@/lib/isoFlags';

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;
if (!accessToken || !refreshToken) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const { data: { user } } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});
if (!user) { Astro.cookies.delete("sb-access-token", { path: "/" }); Astro.cookies.delete("sb-refresh-token", { path: "/" }); return Astro.redirect("/login"); }

const nowMs = betaNowMs();

const [
  { data: matches },
  { data: navProfile },
  { data: myPredictions },
  { data: startedMatchData },
] = await Promise.all([
  supabase.from('matches').select('*').eq('is_finished', false).not('home_team', 'ilike', 'TBD%').not('away_team', 'ilike', 'TBD%').not('home_team', 'ilike', 'Winner%').not('away_team', 'ilike', 'Winner%').order('match_date', { ascending: true }),
  supabase.from('profiles').select('username, puntos_totales, es_referi, pago_70, pago_50').eq('id', user.id).single(),
  supabase.from('predictions').select('match_id, user_home, user_away, user_home_pen, user_away_pen, user_winner_penalties').eq('user_id', user.id),
  supabase.from('matches').select('match_date, is_finished').lte('match_date', new Date(nowMs).toISOString()),
]);

const predMap = new Map(myPredictions?.map(p => [p.match_id, p]) ?? []);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleString('es-BO', {
    weekday: 'short', day: 'numeric', month: 'short',
    hour: '2-digit', minute: '2-digit',
    timeZone: 'America/La_Paz',
    hour12: false
  });
}
function formatTime(dateStr: string): string {
  return new Date(dateStr).toLocaleString('es-BO', {
    hour: '2-digit', minute: '2-digit',
    timeZone: 'America/La_Paz',
    hour12: false
  });
}
function formatShortDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es-BO', {
    weekday: 'short', day: 'numeric', month: 'short',
    timeZone: 'America/La_Paz',
  });
}


type MatchRow = {
  id: string;
  home_team: string;
  away_team: string;
  match_date: string;
  stage: string;
  group_name: string | null;
  round: string | null;
  jornada: string | null;
};

// Agrupar por jornada Bolivia — el día empieza a las 03:00 AM BOT para que
// partidos de medianoche (00:00-02:59) queden con la noche anterior.
const grouped = new Map<string, MatchRow[]>();
for (const m of (matches ?? []) as MatchRow[]) {
  const dayStart = boliviaDayStart(new Date(m.match_date).getTime());
  const key = dayStart.toLocaleDateString('es-BO', {
    weekday: 'long', day: 'numeric', month: 'long',
    timeZone: 'America/La_Paz',
  });
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(m);
}

const now = nowMs;

function toBoliviaDay(dateStr: string): string {
  const dayStart = boliviaDayStart(new Date(dateStr).getTime());
  return dayStart.toLocaleDateString('es-BO', {
    weekday: 'long', day: 'numeric', month: 'long', timeZone: 'America/La_Paz',
  });
}

// Días que ya tuvieron al menos un partido iniciado (terminado o en curso)
const daysWithStartedMatch = new Set(
  (startedMatchData ?? []).map(m => toBoliviaDay(m.match_date))
);
// Hay algún partido en curso ahora mismo (started + unfinished)
const hasMatchInProgress = (startedMatchData ?? []).some(m => !m.is_finished);

function isJornadaClosed(jornadaMatches: MatchRow[]): boolean {
  const firstTime = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
  if (isCutoffPassed(firstTime, now)) return true;
  // Mismo día: ya hubo un partido de este día (aunque terminó)
  if (daysWithStartedMatch.has(toBoliviaDay(jornadaMatches[0].match_date))) return true;
  // Día anterior sin terminar: si existe algún partido abierto con fecha anterior a este día → bloqueado
  if ((matches ?? []).some(m => new Date(m.match_date).getTime() < firstTime)) return true;
  return false;
}

function isPrevDayPending(jornadaMatches: MatchRow[]): boolean {
  const firstTime = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
  if (isCutoffPassed(firstTime, now)) return false;
  if (daysWithStartedMatch.has(toBoliviaDay(jornadaMatches[0].match_date))) return false;
  return (matches ?? []).some(m => new Date(m.match_date).getTime() < firstTime);
}

function isLockedByOngoing(jornadaMatches: MatchRow[]): boolean {
  const firstTime = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
  if (isCutoffPassed(firstTime, now)) return false;
  return daysWithStartedMatch.has(toBoliviaDay(jornadaMatches[0].match_date)) || hasMatchInProgress;
}

function buildShareData(dayMatches: MatchRow[], username: string) {
  const firstMatch = dayMatches[0];
  const cutoff = new Date(new Date(firstMatch.match_date).getTime() - 2 * 3600 * 1000);
  const cutoffStr = cutoff.toLocaleString('es-BO', { hour: '2-digit', minute: '2-digit',
    hour12: false });
  const items = dayMatches
    .filter(m => predMap.has(m.id))
    .map(m => {
      const pred = predMap.get(m.id)!;
      return {
        home: spanishName(m.home_team), away: spanishName(m.away_team),
        homeISO: isoForTeam(m.home_team),
        awayISO: isoForTeam(m.away_team),
        uh: pred.user_home, ua: pred.user_away,
        uhp: pred.user_home_pen ?? null, uap: pred.user_away_pen ?? null,
        pen: pred.user_winner_penalties ?? null,
      };
    });
  return JSON.stringify({ username, cutoff: cutoffStr, items });
}

const errorParam = Astro.url.searchParams.get('error');
const infoParam  = Astro.url.searchParams.get('info');
const okParam    = Astro.url.searchParams.get('ok');

// Contador global de inputs — evita colisiones de nombre entre jornadas distintas
let globalFormIdx = 0;
---

<Layout title="Pronósticos" navProfile={navProfile} isAuthed={true} userId={user.id}>
  <div class="space-y-6">

    <div class="flex items-center justify-between gap-2">
      <h1 class="font-display text-4xl text-white tracking-wide">MIS PRONÓSTICOS</h1>
      <a href="/reglas" class="text-xs text-slate-500 active:text-gold transition py-2 px-1">Reglamento →</a>
    </div>

    {import.meta.env.PUBLIC_BETA !== "true" && !(navProfile?.pago_70 && navProfile?.pago_50) && (
      <div class="bg-brand-900 border border-amber-500/40 rounded-2xl p-8 text-center space-y-3">
        <div class="text-4xl">🔒</div>
        <h2 class="text-white font-bold text-lg">Pronósticos bloqueados</h2>
        <p class="text-slate-400 text-sm max-w-sm mx-auto">
          Para participar debés tener los dos pagos confirmados: <strong class="text-amber-400">70 Bs + 50 Bs</strong>.
          Una vez confirmado por el Réferi, se habilitarán tus pronósticos.
        </p>
        <p class="text-xs text-slate-600 mt-2">¿Ya pagaste? Contactá al Réferi.</p>
      </div>
    )}

    {errorParam === 'cerrado' && (
      <div class="bg-fifared/15 border border-fifared/40 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
        🔒 La jornada ya está cerrada.
      </div>
    )}
    {errorParam === 'en_curso' && (
      <div class="bg-amber-900/20 border border-amber-500/40 rounded-xl px-4 py-3 text-sm text-amber-300 text-center">
        ⏳ Espera que termine el partido antes de pronosticar... ¿o es que ya sabes cómo va a terminar?
      </div>
    )}
    {errorParam === 'incompleto' && (
      <div class="bg-fifared/15 border border-fifared/40 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
        ⚠️ Completa el marcador de todos los partidos antes de enviar.
      </div>
    )}
    {errorParam && errorParam !== 'cerrado' && errorParam !== 'incompleto' && (
      <div class="bg-fifared/15 border border-fifared/40 rounded-xl px-4 py-3 text-sm text-red-300 text-center">
        {decodeURIComponent(errorParam)}
      </div>
    )}
    {infoParam === 'ya_pronosticado' && (
      <div class="bg-brand-700/40 border border-brand-600 rounded-xl px-4 py-3 text-sm text-slate-300 text-center">
        Ya registraste pronósticos para esa jornada.
      </div>
    )}
    {okParam && (
      <div class="bg-gol/10 border border-gol/30 rounded-xl px-4 py-3 text-sm text-green-300 text-center">
        ✅ Pronósticos enviados correctamente.
      </div>
    )}

    {(import.meta.env.PUBLIC_BETA === 'true' || (navProfile?.pago_70 && navProfile?.pago_50)) && grouped.size === 0 && (
      <div class="text-center py-20 text-slate-600">
        <div class="text-5xl mb-4">📅</div>
        <p class="text-base">No hay partidos disponibles por el momento.</p>
      </div>
    )}

    {(import.meta.env.PUBLIC_BETA === 'true' || (navProfile?.pago_70 && navProfile?.pago_50)) && [...grouped.entries()].map(([jornadaKey, jornadaMatches]) => {
      const closed = isJornadaClosed(jornadaMatches);
      const prevPending = isPrevDayPending(jornadaMatches);
      const ongoingLock = isLockedByOngoing(jornadaMatches);
      const predCount = jornadaMatches.filter(m => predMap.has(m.id)).length;
      const allDone = predCount === jornadaMatches.length;
      const hasSome = predCount > 0;
      const unpredicted = jornadaMatches.filter(m => !predMap.has(m.id));
      const firstTime = Math.min(...jornadaMatches.map(m => new Date(m.match_date).getTime()));
      const cutoffStr = new Date(firstTime - 2 * 3600 * 1000).toLocaleString('es-BO', {
        weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit',
        timeZone: 'America/La_Paz',
    hour12: false
      });
      const shareData = buildShareData(jornadaMatches, navProfile?.username ?? 'yo');

      return (
        <div class="space-y-3">

          {/* ── Encabezado de jornada ── */}
          <div class={`flex items-center justify-between px-4 py-3 rounded-xl border ${
            prevPending  ? 'bg-brand-900 border-brand-700/40' :
            ongoingLock  ? 'bg-amber-900/10 border-amber-500/30' :
            closed       ? 'bg-fifared/8 border-fifared/30' :
            allDone      ? 'bg-gol/8 border-gol/30' :
                           'bg-brand-800/60 border-brand-700/60'
          }`}>
            <div>
              <h2 class={`font-display text-xl tracking-wide capitalize ${prevPending ? 'text-slate-500' : 'text-white'}`}>{jornadaKey}</h2>
              <p class={`text-xs mt-0.5 ${prevPending ? 'text-slate-600' : ongoingLock ? 'text-amber-400' : closed ? 'text-fifared' : 'text-slate-500'}`}>
                {prevPending
                  ? '🔒 Disponible cuando terminen los partidos anteriores'
                  : ongoingLock
                  ? '⏳ Esperá que termine el partido de hoy'
                  : closed
                  ? '🔒 Cerrada'
                  : `⏰ Cierre: ${cutoffStr}`
                }
              </p>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <span class={`text-xs px-2 py-1 rounded-full border ${
                allDone    ? 'text-gol border-gol/30 bg-gol/10' :
                hasSome    ? 'text-amarilla border-amarilla/30 bg-amarilla/10' :
                prevPending ? 'text-slate-600 border-brand-700/40 bg-brand-800/40' :
                closed     ? 'text-fifared border-fifared/30 bg-fifared/10' :
                              'text-slate-500 border-brand-600 bg-brand-700/30'
              }`}>
                {allDone
                  ? '✅ Completa'
                  : hasSome
                  ? `${predCount}/${jornadaMatches.length}`
                  : prevPending
                  ? '⏳ Jornada anterior abierta'
                  : ongoingLock
                  ? '⏳ Partido en curso'
                  : closed
                  ? '🔒 Cerrada sin pronóstico'
                  : `0/${jornadaMatches.length}`}
              </span>
              {hasSome && (
                <button
                  class="share-btn flex items-center gap-1.5 text-xs font-semibold text-white px-3 py-2 rounded-xl transition active:opacity-80 min-h-[44px]"
                  style="background-color:#25D366"
                  data-share={shareData}>
                  <svg viewBox="0 0 24 24" class="w-4 h-4 flex-shrink-0" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  <span>Compartir</span>
                </button>
              )}
            </div>
          </div>

          {/* ── Si la jornada está abierta y hay partidos sin pronosticar: form inline ── */}
          {!closed && !allDone ? (
            <form method="POST" action="/api/predictions/submit-jornada" class="space-y-2">

              {jornadaMatches.map((m) => {
                const existing = predMap.get(m.id);
                const homeISO = isoForTeam(m.home_team);
                const awayISO = isoForTeam(m.away_team);
                const idx = existing ? -1 : globalFormIdx++;
                const isKnockout = m.stage === 'knockout';

                return (
                  <div class={`bg-brand-900 border rounded-2xl p-4 ${existing ? 'border-gol/30 bg-gol/5' : 'border-brand-700/60'}`}>

                    {/* Fecha + etiqueta */}
                    <div class="flex items-center justify-between mb-3">
                      <span class="text-slate-400 font-medium text-xs">
                        {m.stage === 'group' ? (m.group_name ? `Grupo ${m.group_name}` : m.jornada) : m.round}
                      </span>
                      <div class="text-right">
                        <p class="text-xs text-slate-500">{formatShortDate(m.match_date)}</p>
                        <p class="font-display text-base font-bold text-gold leading-tight">{formatTime(m.match_date)}</p>
                      </div>
                    </div>

                    {/* Equipos + inputs */}
                    {existing ? (
                      /* Ya pronosticado: layout horizontal clásico */
                      <div class="flex items-center gap-2">
                        <div class="flex-1 text-right">
                          <span class="text-white font-semibold text-base leading-tight">
                            {spanishName(m.home_team)}
                            {homeISO && <span class="flag-emoji ml-1" data-iso={homeISO}></span>}
                          </span>
                        </div>
                        <span class="text-gol font-display text-3xl flex-shrink-0 px-2">
                          {existing.user_home}–{existing.user_away}
                        </span>
                        <div class="flex-1">
                          <span class="text-white font-semibold text-base leading-tight">
                            {awayISO && <span class="flag-emoji mr-1" data-iso={awayISO}></span>}
                            {spanishName(m.away_team)}
                          </span>
                        </div>
                      </div>
                    ) : (
                      /* Sin pronóstico: nombres arriba, steppers abajo */
                      <div class="space-y-3">
                        <input type="hidden" name={`matchId_${idx}`} value={m.id} />
                        <div class="flex items-center justify-between gap-2">
                          <span class="flex-1 text-right text-white font-semibold text-base leading-tight">
                            {spanishName(m.home_team)}
                            {homeISO && <span class="flag-emoji ml-1" data-iso={homeISO}></span>}
                          </span>
                          <span class="text-slate-600 text-sm flex-shrink-0">vs</span>
                          <span class="flex-1 text-left text-white font-semibold text-base leading-tight">
                            {awayISO && <span class="flag-emoji mr-1" data-iso={awayISO}></span>}
                            {spanishName(m.away_team)}
                          </span>
                        </div>
                        <div class="flex items-center justify-center gap-2">
                          {/* Stepper local */}
                          <div class="flex items-center gap-1">
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="dec" data-target={`home_${idx}`}>−</button>
                            <input
                              type="number" inputmode="numeric" pattern="[0-9]*"
                              name={`home_${idx}`}
                              min="0" max="20" required value="0"
                              class="w-14 bg-brand-800 border-2 border-brand-700 rounded-xl py-2 text-white text-2xl font-display text-center focus:outline-none focus:border-gold transition"
                            />
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="inc" data-target={`home_${idx}`}>+</button>
                          </div>
                          <span class="text-slate-500 font-bold text-xl px-1">–</span>
                          {/* Stepper visitante */}
                          <div class="flex items-center gap-1">
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="dec" data-target={`away_${idx}`}>−</button>
                            <input
                              type="number" inputmode="numeric" pattern="[0-9]*"
                              name={`away_${idx}`}
                              min="0" max="20" required value="0"
                              class="w-14 bg-brand-800 border-2 border-brand-700 rounded-xl py-2 text-white text-2xl font-display text-center focus:outline-none focus:border-gold transition"
                            />
                            <button type="button"
                              class="stepper-btn w-10 h-10 rounded-xl bg-brand-700 active:bg-brand-600 text-white text-xl font-bold flex items-center justify-center transition touch-manipulation select-none"
                              data-action="inc" data-target={`away_${idx}`}>+</button>
                          </div>
                        </div>
                      </div>
                    )}

                    {/* Penales (knockout sin pronóstico) */}
                    {isKnockout && !existing && (
                      <div
                        class="hidden mt-3 pt-3 border-t border-brand-800 space-y-2"
                        data-pen-section={`pen-section-${idx}`}
                      >
                        <p class="text-xs text-gold text-center font-semibold">⚡ Score en penales <span class="text-slate-500 font-normal">(solo si hay empate)</span></p>
                        <div class="flex items-center gap-2">
                          <div class="flex-1 text-center space-y-1">
                            <span class="text-xs text-slate-500 block truncate">{spanishName(m.home_team)}</span>
                            <input
                              type="number"
                              inputmode="numeric"
                              pattern="[0-9]*"
                              name={`pen_home_${idx}`}
                              min="0" max="20" placeholder="0"
                              class="w-full bg-gold/10 border-2 border-gold/40 rounded-xl py-3 text-gold text-2xl font-display text-center focus:outline-none focus:border-gold transition placeholder:text-gold/30"
                              data-pen-input={`pen-section-${idx}`}
                            />
                          </div>
                          <span class="text-gold/40 font-bold text-xl flex-shrink-0">–</span>
                          <div class="flex-1 text-center space-y-1">
                            <span class="text-xs text-slate-500 block truncate">{spanishName(m.away_team)}</span>
                            <input
                              type="number"
                              inputmode="numeric"
                              pattern="[0-9]*"
                              name={`pen_away_${idx}`}
                              min="0" max="20" placeholder="0"
                              class="w-full bg-gold/10 border-2 border-gold/40 rounded-xl py-3 text-gold text-2xl font-display text-center focus:outline-none focus:border-gold transition placeholder:text-gold/30"
                              data-pen-input={`pen-section-${idx}`}
                            />
                          </div>
                        </div>
                        <p class="text-xs text-slate-600 text-center">El ganador en penales se determina automáticamente</p>
                      </div>
                    )}

                    {/* Ya pronosticado: mostrar score de penales si aplica */}
                    {existing && (existing.user_home_pen !== null || existing.user_winner_penalties) && (
                      <p class="text-xs text-slate-500 text-center mt-2">
                        Penales: <span class="text-gold">
                          {existing.user_home_pen !== null
                            ? `${existing.user_home_pen} – ${existing.user_away_pen}`
                            : existing.user_winner_penalties === 'home' ? spanishName(m.home_team) : spanishName(m.away_team)
                          }
                        </span>
                      </p>
                    )}
                  </div>
                );
              })}

              <button type="submit"
                class="w-full bg-gold text-brand-950 font-bold py-4 rounded-2xl transition active:bg-gold-dark text-base min-h-[52px] mt-1">
                Enviar pronósticos de la jornada ✅
              </button>
              <p class="text-xs text-slate-600 text-center pb-1">
                Tolerancia Cero — una vez enviado no se puede modificar.
              </p>
            </form>

          ) : (
            /* ── Jornada cerrada o completa: solo lectura ── */
            <div class="space-y-2">
              {jornadaMatches.map((m) => {
                const existing = predMap.get(m.id);
                const homeISO = isoForTeam(m.home_team);
                const awayISO = isoForTeam(m.away_team);
                return (
                  <div class={`bg-brand-900 border rounded-2xl p-4 ${existing ? 'border-gol/30 bg-gol/5' : prevPending ? 'border-brand-700/40 bg-brand-800/30' : 'border-fifared/30 bg-fifared/5'}`}>
                    <div class="flex items-center justify-between mb-2">
                      <span class="text-slate-400 font-medium text-xs">
                        {m.stage === 'group' ? (m.group_name ? `Grupo ${m.group_name}` : m.jornada) : m.round}
                      </span>
                      <div class="text-right">
                        <p class="text-xs text-slate-500">{formatShortDate(m.match_date)}</p>
                        <p class="font-display text-base font-bold text-gold leading-tight">{formatTime(m.match_date)}</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-2">
                      <div class="flex-1 text-right">
                        <span class={`font-semibold text-base ${existing ? 'text-white' : 'text-slate-400'}`}>
                          {spanishName(m.home_team)}
                          {homeISO && <span class="flag-emoji ml-1" data-iso={homeISO}></span>}
                        </span>
                      </div>
                      <div class="flex-shrink-0 px-2 text-center min-w-[60px]">
                        {existing
                          ? <span class="text-gol font-display text-2xl">{existing.user_home}–{existing.user_away}</span>
                          : <span class="text-slate-700 font-bold text-xl">–</span>
                        }
                      </div>
                      <div class="flex-1">
                        <span class={`font-semibold text-base ${existing ? 'text-white' : 'text-slate-400'}`}>
                          {awayISO && <span class="flag-emoji mr-1" data-iso={awayISO}></span>}
                          {spanishName(m.away_team)}
                        </span>
                      </div>
                    </div>
                    {existing && (existing.user_home_pen !== null || existing.user_winner_penalties) && (
                      <p class="text-xs text-slate-500 text-center mt-1.5">
                        Penales: <span class="text-gold">
                          {existing.user_home_pen !== null
                            ? `${existing.user_home_pen} – ${existing.user_away_pen}`
                            : existing.user_winner_penalties === 'home' ? spanishName(m.home_team) : spanishName(m.away_team)
                          }
                        </span>
                      </p>
                    )}
                    {!existing && (
                      <button disabled class="w-full mt-2 flex items-center justify-center gap-2 text-sm text-slate-300 bg-brand-800/50 border border-brand-700/50 rounded-xl py-3 cursor-not-allowed opacity-75">
                        {prevPending
                          ? '⏳ Espera que terminen los partidos anteriores'
                          : ongoingLock
                          ? '⏳ El partido ya comenzó, sin pronóstico'
                          : '🔒 Jornada cerrada, sin pronóstico'}
                      </button>
                    )}
                  </div>
                );
              })}
            </div>
          )}

        </div>
      );
    })}
  </div>
</Layout>

<script>
  async function waShare(text: string) {
    // 1. Web Share API nativo (mobile Chrome/Safari — más confiable)
    if (navigator.share) {
      try { await navigator.share({ text }); return; } catch (e) {
        if ((e as Error).name === 'AbortError') return; // usuario canceló
      }
    }
    const waUrl = 'https://wa.me/?text=' + encodeURIComponent(text);
    // 2. Mobile sin Web Share API: abrir wa.me
    if (/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) {
      window.open(waUrl, '_blank'); return;
    }
    // 3. Desktop: intentar clipboard; si falla, abrir wa.me web
    let copied = false;
    try { await navigator.clipboard.writeText(text); copied = true; } catch { /**/ }
    if (!copied) { window.open(waUrl, '_blank'); return; }
    const el = document.createElement('div');
    el.textContent = '\uD83D\uDCCB Copiado \u2014 peg\u00e1lo en WhatsApp con Ctrl+V';
    el.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0d1117;border:1px solid #25d366;color:#fff;padding:12px 20px;border-radius:12px;font-size:14px;z-index:9999;pointer-events:none;white-space:nowrap';
    document.body.appendChild(el);
    setTimeout(() => { el.style.transition = 'opacity .3s'; el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 3500);
  }

  // Generar emojis de bandera en runtime
  function flagFromISO(cc: string): string {
    const base = 0x1F1E6 - 65;
    return String.fromCodePoint(cc.charCodeAt(0) + base, cc.charCodeAt(1) + base);
  }

  function initFlags() {
    document.querySelectorAll<HTMLSpanElement>('.flag-emoji').forEach(el => {
      const iso = el.dataset.iso;
      if (iso) el.textContent = flagFromISO(iso);
    });
  }

  // Mostrar selector de penales en partidos de knockout cuando hay empate
  function initPenaltySections() {
    document.querySelectorAll<HTMLInputElement>('input[type="number"]').forEach(input => {
      const name = input.name; // home_N o away_N
      const match = name.match(/^(home|away)_(\d+)$/);
      if (!match) return;
      const idx = match[2];
      const section = document.querySelector<HTMLElement>(`[data-pen-section="pen-section-${idx}"]`);
      if (!section) return;

      function check() {
        const homeVal = (document.querySelector<HTMLInputElement>(`input[name="home_${idx}"]`))?.value;
        const awayVal = (document.querySelector<HTMLInputElement>(`input[name="away_${idx}"]`))?.value;
        const h = parseInt(homeVal ?? '');
        const a = parseInt(awayVal ?? '');
        if (!isNaN(h) && !isNaN(a) && h === a) {
          section!.classList.remove('hidden');
        } else {
          section!.classList.add('hidden');
          section!.querySelectorAll<HTMLInputElement>('input[type="number"]').forEach(r => { r.value = ''; });
        }
      }
      input.addEventListener('input', check);
    });
  }

  // WhatsApp share
  function buildText(data: {
    username: string; cutoff: string;
    items: Array<{ home: string; away: string; homeISO: string; awayISO: string; uh: number; ua: number; uhp: number|null; uap: number|null; pen: string | null }>;
  }) {
    const lines = [
      `\u26BD *Pron\u00f3sticos de ${data.username}*`,
      `_Cierre: ${data.cutoff}_`,
      '',
    ];
    data.items.forEach(item => {
      const hf = item.homeISO ? flagFromISO(item.homeISO) : '';
      const af = item.awayISO ? flagFromISO(item.awayISO) : '';
      lines.push(`${item.home} ${hf} ${item.uh}\u2013${item.ua} ${af} ${item.away}`);
      if (item.pen) {
        const wf    = item.pen === 'home' ? hf : af;
        const wName = item.pen === 'home' ? item.home : item.away;
        const penScore = item.uhp !== null ? `${item.uhp}\u2013${item.uap} pen \u00B7 ` : '';
        lines.push(`_(${penScore}clasifica ${wf} ${wName})_`);
      }
      lines.push('');
    });
    lines.push(`_Polla Mundial 2026_ \uD83C\uDFC6`);
    return lines.join('\n');
  }

  function initShareButtons() {
    document.querySelectorAll<HTMLButtonElement>('.share-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const data = JSON.parse(btn.dataset.share ?? '{}');
        waShare(buildText(data));
      });
    });
  }

  function initSubmitButtons() {
    document.querySelectorAll<HTMLFormElement>('form[action="/api/predictions/submit-jornada"]').forEach(form => {
      form.addEventListener('submit', () => {
        // Botón: feedback inmediato
        const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        if (btn) {
          btn.disabled = true;
          btn.textContent = '✅ Enviando…';
          btn.classList.remove('bg-gold', 'active:bg-gold-dark');
          btn.classList.add('bg-gol', 'opacity-80', 'cursor-not-allowed');
        }
        // Cards de partidos: borde + fondo verde
        form.querySelectorAll<HTMLElement>('div.bg-brand-900').forEach(card => {
          card.classList.remove('border-brand-700\\/60');
          card.classList.add('border-gol/40', 'bg-gol/5');
        });
      });
    });
  }

  function initSteppers() {
    document.querySelectorAll<HTMLButtonElement>('.stepper-btn').forEach(btn => {
      if (btn._stepInit) return;
      btn._stepInit = true;
      btn.addEventListener('click', () => {
        const input = document.querySelector<HTMLInputElement>(`input[name="${btn.dataset.target}"]`);
        if (!input) return;
        const val = parseInt(input.value) || 0;
        const next = btn.dataset.action === 'inc' ? Math.min(val + 1, 20) : Math.max(val - 1, 0);
        input.value = String(next);
        input.dispatchEvent(new Event('input', { bubbles: true }));
      });
    });
  }

  function init() {
    initFlags();
    initSteppers();
    initPenaltySections();
    initShareButtons();
    initSubmitButtons();
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
